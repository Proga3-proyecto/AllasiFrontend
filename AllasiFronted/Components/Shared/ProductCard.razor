@using Progra3_Frontend.Model
@using Progra3_Frontend.Services
@inject NavigationManager NavigationManager
@inject CarritoStateService CarritoService
@inject ToastService ToastService
@inject Microsoft.AspNetCore.Components.Authorization.AuthenticationStateProvider AuthStateProvider

<div class="product-card" @onclick="NavigateToDetail" style="cursor: pointer;">
    @if (Rank > 0)
    {
        <div class="product-rank">@Rank</div>
    }
    <div class="product-image">
        <img src="@GetImageUrl()" alt="@GetTitle()" />
    </div>
    <div class="product-info">
        <h3 class="product-title">@GetTitle()</h3>
        @if (!string.IsNullOrEmpty(GetSubtitle()))
        {
            <p class="product-category">@GetSubtitle()</p>
        }
        <div class="product-bottom">
            <span class="product-price">S/ @GetPrice().ToString("0.00")</span>
            <button class="cart-button" title="Añadir al carrito" @onclick="AddToCart" @onclick:stopPropagation><i class="bi bi-cart"></i></button>
        </div>
    </div>
</div>

@code {
    [Parameter] public int Rank { get; set; }
    [Parameter] public Producto? ProductoItem { get; set; }
    [Parameter] public Receta? RecetaItem { get; set; }

    private void NavigateToDetail()
    {
        if (ProductoItem != null)
        {
            NavigationManager.NavigateTo($"/producto/{ProductoItem.id}");
        }
        else if (RecetaItem != null)
        {
            NavigationManager.NavigateTo($"/receta/{RecetaItem.id}");
        }
    }

    private string GetImageUrl()
    {
        if (ProductoItem != null && ProductoItem.imagenes != null && ProductoItem.imagenes.Any()) return  ProductoItem.imagenes.Find(i=>i.principal)?.url ?? "";
        if (RecetaItem != null && RecetaItem.imagenes != null && RecetaItem.imagenes.Any()) return RecetaItem.imagenes.Find(i=>i.principal)?.url ?? "";
        return "/assets/placeholder-bottle.png"; // Fallback image
    }

    private string GetTitle()
    {
        if (ProductoItem != null) return ProductoItem.nombre ?? "Producto Sin Nombre";
        if (RecetaItem != null) return RecetaItem.nombre ?? "Receta Sin Nombre";
        return "Producto";
    }

    private string GetSubtitle()
    {
        if (ProductoItem != null)
        {
            if (ProductoItem.marca != null && !string.IsNullOrWhiteSpace(ProductoItem.marca.nombre))
                return ProductoItem.marca.nombre;
            if (ProductoItem.categorias != null && ProductoItem.categorias.Any())
                return ProductoItem.categorias[0].nombre ?? "Categoría";
            return "Marca";
        }
        return ""; // No subtitle for recipes
    }

    private double GetPrice()
    {
        if (ProductoItem != null) return ProductoItem.precioFinal;
        if (RecetaItem != null) return RecetaItem.precioFinal;
        return 0.00;
    }

    private async Task AddToCart()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity == null || !authState.User.Identity.IsAuthenticated)
        {
            ToastService.ShowToast("No se puede agregar al carrito si no estás registrado.", "warning");
            return;
        }

        if (ProductoItem != null)
        {
            CarritoService.AgregarProducto(ProductoItem, 1);
        }
        else if (RecetaItem != null)
        {
            CarritoService.AgregarReceta(RecetaItem, 1);
        }
    }
}

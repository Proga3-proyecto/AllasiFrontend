@inherits ComponentBase
@implements IDisposable
@inject NavigationManager NavigationManager
@using Progra3_Frontend.Services
@using Microsoft.AspNetCore.Components.Authorization
@inject CarritoStateService CarritoService

<header class="navbar-header">
    <div class="top-bar">
        <div class="contact-info">
            <span class="contact-item"><i class="bi bi-envelope"></i> CONSULTASCLIENTES@LICORERIAALLASI.COM</span>
            <span class="divider">|</span>
            <span class="contact-item"><i class="bi bi-telephone"></i> (01) 123-4567</span>
            <span class="divider">|</span>
            <span class="contact-item"><i class="bi bi-geo-alt"></i> AV. UNIVERSITARIA 1801, SAN MIGUEL, LIMA</span>
        </div>
    </div>
    
    <div class="middle-bar">
        <div class="mobile-toggle" @onclick="ToggleMenu">
            <i class="bi @(isMenuOpen ? "bi-x" : "bi-list")"></i>
        </div>
        
        <div class="logo-container">
            <a href="/">
                <img src="/assets/logo.png" alt="allasi licores" class="logo" />
            </a>
        </div>
        
        <div class="search-container">
            <div class="search-input-wrapper">
                <input type="text" class="search-input" placeholder="¿Qué buscas hoy?" @bind="searchQuery" @bind:event="oninput" @onkeyup="HandleKeyUp" />
                <i class="bi bi-search search-icon" @onclick="ExecuteSearch" style="cursor: pointer;"></i>
            </div>
        </div>
        
        <div class="user-actions">
            <UserMenu IsLoggedIn="@IsLoggedIn" UserName="@UserName" />
            
            @if (!IsAdmin && IsLoggedIn)
            {
                <a href="/cart" class="action-icon cart-icon-wrapper">
                    <i class="bi bi-cart"></i>
                    <span class="cart-badge">@CarritoService.ObtenerCantidadTotal()</span>
                </a>
            }
            @if(!IsLoggedIn)
            {
                <a href="/login" class="action-icon cart-icon-wrapper">
                    <i class="bi bi-cart"></i>
                    <span class="cart-badge">@CarritoService.ObtenerCantidadTotal()</span>
                </a>
            }
    
        </div>
    </div>
    
    <nav class="bottom-bar @(isMenuOpen ? "open" : "")">
        <div class="mobile-search-container">
             <div class="search-input-wrapper">
                <input type="text" class="search-input" placeholder="¿Qué buscas hoy?" @bind="searchQuery" @bind:event="oninput" @onkeyup="HandleKeyUp" />
                <i class="bi bi-search search-icon" @onclick="ExecuteSearch" style="cursor: pointer;"></i>
            </div>
        </div>
        <ul class="nav-links">
            <li><NavLink href="/" Match="NavLinkMatch.All">INICIO</NavLink></li>
            <li><NavLink href="/products/all">ALL</NavLink></li>
            <li><NavLink href="/products/ron">RON</NavLink></li>
            <li><NavLink href="/products/vodka">VODKA</NavLink></li>
            <li><NavLink href="/products/whisky">WHISKY</NavLink></li>
            <li><NavLink href="/products/gin">GIN</NavLink></li>
            <li><NavLink href="/products/pisco">PISCO</NavLink></li>
            <li><NavLink href="/products/vino">VINO</NavLink></li>
            <li><NavLink href="/recetas">RECETAS</NavLink></li>
        </ul>
        
        <div class="mobile-contact-info">
            <div class="mobile-contact-item"><i class="bi bi-envelope"></i> CONSULTASCLIENTES@LICORERIAALLASI.COM</div>
            <div class="mobile-contact-item"><i class="bi bi-telephone"></i> (01) 123-4567</div>
            <div class="mobile-contact-item"><i class="bi bi-geo-alt"></i> AV. UNIVERSITARIA 1801, SAN MIGUEL, LIMA</div>
        </div>
    </nav>
</header>

@code {
    private bool isMenuOpen = false;
    private string _searchQuery = string.Empty;
    private string searchQuery
    {
        get => _searchQuery;
        set
        {
            if (_searchQuery != value)
            {
                _searchQuery = value;
                OnSearchQueryChanged();
            }
        }
    }

    private System.Threading.CancellationTokenSource? _searchCts;

    private bool IsLoggedIn = false;
    private string UserName = "";
    private bool IsAdmin = false;

    [Inject] private AuthenticationStateProvider AuthProvider { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        NavigationManager.LocationChanged += OnLocationChanged;
        CarritoService.OnChange += OnCartChanged;
        UpdateSearchQueryFromUri(NavigationManager.Uri);

        AuthProvider.AuthenticationStateChanged += OnAuthenticationStateChanged;
        var state = await AuthProvider.GetAuthenticationStateAsync();
        UpdateAuthState(state);
    }

    private void UpdateAuthState(AuthenticationState state)
    {
        var user = state.User;
        if (user.Identity != null && user.Identity.IsAuthenticated)
        {
            IsLoggedIn = true;
            UserName = user.Identity.Name ?? "";
            IsAdmin = user.IsInRole("ADMIN") || user.IsInRole("Admin") || user.IsInRole("admin");
        }
        else
        {
            IsLoggedIn = false;
            UserName = "";
            IsAdmin = false;
        }
    }

    private async void OnAuthenticationStateChanged(Task<AuthenticationState> task)
    {
        var state = await task;
        UpdateAuthState(state);
        await InvokeAsync(StateHasChanged);
    }

    private void OnCartChanged()
    {
        StateHasChanged();
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        UpdateSearchQueryFromUri(e.Location);
        StateHasChanged();
    }

    private void UpdateSearchQueryFromUri(string uri)
    {
        try
        {
            var absoluteUri = new Uri(uri);
            var query = absoluteUri.Query;
            if (string.IsNullOrEmpty(query))
            {
                _searchQuery = string.Empty;
                return;
            }

            var match = System.Text.RegularExpressions.Regex.Match(query, @"[?&]search=([^&]*)");
            if (match.Success)
            {
                _searchQuery = Uri.UnescapeDataString(match.Groups[1].Value);
            }
            else
            {
                _searchQuery = string.Empty;
            }
        }
        catch
        {
            _searchQuery = string.Empty;
        }
    }

    private void ToggleMenu()
    {
        isMenuOpen = !isMenuOpen;
    }

    private async void OnSearchQueryChanged()
    {
        _searchCts?.Cancel();
        _searchCts = new System.Threading.CancellationTokenSource();
        var token = _searchCts.Token;

        try
        {
            await Task.Delay(250, token);
            if (!token.IsCancellationRequested)
            {
                ExecuteSearch();
            }
        }
        catch (TaskCanceledException)
        {
            // Omitido
        }
    }

    private void ExecuteSearch()
    {
        if (!string.IsNullOrWhiteSpace(_searchQuery))
        {
            NavigationManager.NavigateTo($"/products/all?search={Uri.EscapeDataString(_searchQuery)}");
        }
        else
        {
            NavigationManager.NavigateTo("/products/all");
        }
    }

    private void HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            _searchCts?.Cancel();
            ExecuteSearch();
        }
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
        CarritoService.OnChange -= OnCartChanged;
        if (AuthProvider != null)
        {
            AuthProvider.AuthenticationStateChanged -= OnAuthenticationStateChanged;
        }
        _searchCts?.Cancel();
        _searchCts?.Dispose();
    }
}

<div class="banner-carousel">

    @if (currentIndex == 0)
    {
        <div class="banner-content">
            <h1>
                LOS MEJORES LICORES,<br />
                PARA LOS MEJORES MOMENTOS.
            </h1>

            <p>
                Descubre nuestra selección de licores premium<br />
                y encuentra tu favorito.
            </p>
        </div>
    }

    <div class="banner-image">
        @foreach (var img in images)
        {
            <img src="@img"
                 alt="Licores"
                 class="carousel-img @(img == images[currentIndex] ? "active" : "")" />
        }
    </div>

    <div class="carousel-indicators">
        @for (int i = 0; i < images.Length; i++)
        {
            int index = i;

            <span class="indicator @(i == currentIndex ? "active" : "")"
                  @onclick="() => SetImage(index)">
            </span>
        }
    </div>

</div>

@code {
    private int currentIndex = 0;

    private readonly string[] images =
    {
        "/assets/inicio.png",
        "/assets/banner/banner1.webp",
        "/assets/banner/banner2.webp"
    };

    private void SetImage(int index)
    {
        currentIndex = index;
    }
}

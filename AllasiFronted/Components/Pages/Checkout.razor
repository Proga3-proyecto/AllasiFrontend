@page "/checkout"
@using Progra3_Frontend.Model
@using Progra3_Frontend.Services
@using Microsoft.AspNetCore.Components.Authorization
@inject CarritoStateService CarritoService
@inject PedidosRS PedidosService
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthStateProvider
@inject ClientesRS ClientesService

<PageTitle>Finalizar Compra - Allasi Licores</PageTitle>

<div class="checkout-page">
    <div class="category-banner">
        <div class="banner-content">
            <h1 class="banner-title">FINALIZAR COMPRA</h1>
            <div class="banner-separator">
                <span class="line"></span>
                <i class="bi bi-credit-card banner-icon"></i>
                <span class="line"></span>
            </div>
            <p class="banner-subtitle">
                Ingresa tus datos para completar el pedido
            </p>
        </div>
    </div>

    <div class="checkout-container">
        @if (CarritoService.Productos.Count == 0 && CarritoService.Recetas.Count == 0)
        {
            <div class="empty-checkout">
                <i class="bi bi-cart-x empty-icon"></i>
                <h2>Tu carrito está vacío</h2>
                <p>No puedes proceder al pago sin productos.</p>
                <button class="btn-shop" @onclick='() => NavigationManager.NavigateTo("/products/all")'>Volver a la tienda</button>
            </div>
        }
        else
        {
            <div class="checkout-grid">
                <div class="checkout-form-section">
                    <h3>Datos de Envío y Pago</h3>
                    <form @onsubmit="RealizarPago">
                        <div class="form-group">
                            <label for="direccion">Dirección de Entrega</label>
                            <div style="display: flex; gap: 10px;">
                                <select id="direccion" class="form-control" @bind="direccion" required>
                                    @if (savedAddresses.Count == 0)
                                    {
                                        <option value="" disabled selected>No tienes direcciones guardadas</option>
                                    }
                                    else
                                    {
                                        @foreach (var dir in savedAddresses)
                                        {
                                            <option value="@dir">@dir</option>
                                        }
                                    }
                                </select>
                                <button type="button" class="btn btn-outline-primary" @onclick="AbrirModalDireccion" style="white-space: nowrap; height: fit-content; align-self: center;">
                                    <i class="bi bi-plus-lg"></i> Agregar
                                </button>
                            </div>
                        </div>
                        <div class="form-group">
                            <label for="referencia">Referencia (Opcional)</label>
                            <input type="text" id="referencia" class="form-control" @bind="referencia" placeholder="Cerca al parque central" />
                        </div>
                        <div class="form-group">
                            <label for="metodoPago">Método de Pago</label>
                            <select id="metodoPago" class="form-control" @bind="metodoPago">
                                <option value="tarjeta">Tarjeta de Crédito / Débito</option>
                                <option value="yape">Yape / Plin</option>
                                <option value="contraentrega">Pago Contraentrega</option>
                            </select>
                            <small class="hint-text">El pago será procesado según el método seleccionado.</small>
                        </div>
                        
                        @if (!string.IsNullOrEmpty(errorMessage))
                        {
                            <div class="error-alert">
                                <i class="bi bi-exclamation-circle"></i> @errorMessage
                            </div>
                        }

                        <div class="form-actions">
                            @if (isProcessing)
                            {
                                <button type="button" class="btn-checkout loading" disabled>
                                    Procesando pago...
                                </button>
                            }
                            else
                            {
                                <button type="submit" class="btn-checkout">PAGAR S/ @Total.ToString("0.00")</button>
                            }
                        </div>
                    </form>
                </div>

                <div class="checkout-summary-section">
                    <div class="summary-card">
                        <h3>RESUMEN DE COMPRA</h3>
                        <div class="summary-divider"></div>
                        <div class="summary-items">
                            @foreach(var item in CarritoService.Productos)
                            {
                                <div class="summary-item">
                                    <div class="item-details">
                                        <span class="item-name">@item.producto.nombre</span>
                                        <span class="item-qty">Cant: @item.cantidad</span>
                                    </div>
                                    <span class="item-price">S/ @item.montoTotal.ToString("0.00")</span>
                                </div>
                            }
                            @foreach(var item in CarritoService.Recetas)
                            {
                                <div class="summary-item">
                                    <div class="item-details">
                                        <span class="item-name">@item.receta.nombre</span>
                                        <span class="item-qty">Cant: @item.cantidad</span>
                                    </div>
                                    <span class="item-price">S/ @item.montoTotal.ToString("0.00")</span>
                                </div>
                            }
                        </div>
                        <div class="summary-divider"></div>
                        <div class="summary-row">
                            <span>Subtotal</span>
                            <span>S/ @Subtotal.ToString("0.00")</span>
                        </div>
                        <div class="summary-row">
                            <span>Envío</span>
                            <span>S/ @Delivery.ToString("0.00")</span>
                        </div>
                        <div class="summary-divider"></div>
                        <div class="summary-row total-row">
                            <span>TOTAL</span>
                            <span>S/ @Total.ToString("0.00")</span>
                        </div>
                        <p class="taxes-label">Impuestos incluidos</p>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@if (showAddressModal)
{
    <div class="custom-modal-overlay" @onclick="CerrarModalDireccion">
        <div class="custom-modal-content" @onclick:stopPropagation="true">
            <div class="custom-modal-header">
                <h5 class="custom-modal-title">Agregar nueva dirección</h5>
                <button type="button" class="custom-modal-close" aria-label="Close" @onclick="CerrarModalDireccion">&times;</button>
            </div>
            <div class="custom-modal-body">
                <input type="text" class="form-control" @bind="nuevaDireccionCheckout" placeholder="Ej: Av. Principal 123, Distrito" />
                @if (!string.IsNullOrEmpty(addressModalError))
                {
                    <div class="text-danger mt-2" style="font-size: 0.85rem;">@addressModalError</div>
                }
            </div>
            <div class="custom-modal-footer">
                <button type="button" class="btn-cancel" @onclick="CerrarModalDireccion">Cancelar</button>
                <button type="button" class="btn-save" @onclick="GuardarNuevaDireccion">Guardar</button>
            </div>
        </div>
    </div>
}

@code {
    private string direccion = "";
    private string referencia = "";
    private string metodoPago = "tarjeta";
    private bool isProcessing = false;
    private string errorMessage = "";
    private int? userId = null;
    private Cliente? currentClient = null;
    private List<string> savedAddresses = new();
    
    private bool showAddressModal = false;
    private string nuevaDireccionCheckout = "";
    private string addressModalError = "";

    private double Subtotal => CarritoService.ObtenerTotal();
    private double Delivery => Subtotal > 0 ? 15.00 : 0.00;
    private double Total => Subtotal + Delivery;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity != null && user.Identity.IsAuthenticated)
        {
            var userIdClaim = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            if (int.TryParse(userIdClaim, out int uid))
            {
                userId = uid;
                currentClient = await ClientesService.GetClienteAsync(uid);
                if (currentClient?.direcciones != null)
                {
                    savedAddresses = currentClient.direcciones.Select(d => d.direccion).ToList();
                    if (savedAddresses.Any())
                    {
                        direccion = savedAddresses.First();
                    }
                }
            }
        }
    }

    private void AbrirModalDireccion()
    {
        nuevaDireccionCheckout = "";
        addressModalError = "";
        showAddressModal = true;
    }

    private void CerrarModalDireccion()
    {
        showAddressModal = false;
    }

    private async Task GuardarNuevaDireccion()
    {
        addressModalError = "";
        if (string.IsNullOrWhiteSpace(nuevaDireccionCheckout))
        {
            addressModalError = "La dirección no puede estar vacía.";
            return;
        }

        if (currentClient != null)
        {
            try
            {
                currentClient.direcciones ??= new List<ClienteDireccion>();
                currentClient.direcciones.Add(new ClienteDireccion { direccion = nuevaDireccionCheckout.Trim() });
                
                var resultado = await ClientesService.ActualizarAsync(currentClient);
                if (resultado)
                {
                    savedAddresses.Add(nuevaDireccionCheckout.Trim());
                    direccion = nuevaDireccionCheckout.Trim();
                    showAddressModal = false;
                }
                else
                {
                    addressModalError = "Error al guardar la dirección.";
                    currentClient.direcciones.RemoveAt(currentClient.direcciones.Count - 1);
                }
            }
            catch (Exception ex)
            {
                addressModalError = "Error de red: " + ex.Message;
                currentClient.direcciones.RemoveAt(currentClient.direcciones.Count - 1);
            }
        }
        else
        {
            savedAddresses.Add(nuevaDireccionCheckout.Trim());
            direccion = nuevaDireccionCheckout.Trim();
            showAddressModal = false;
        }
    }

    private async Task RealizarPago()
    {
        if (string.IsNullOrWhiteSpace(direccion))
        {
            errorMessage = "La dirección de entrega es requerida.";
            return;
        }

        if (userId == null)
        {
            errorMessage = "Debes iniciar sesión para realizar un pedido.";
            return;
        }

        isProcessing = true;
        errorMessage = "";
        
        try
        {
            if (currentClient != null && !savedAddresses.Contains(direccion.Trim(), StringComparer.OrdinalIgnoreCase))
            {
                currentClient.direcciones ??= new List<ClienteDireccion>();
                currentClient.direcciones.Add(new ClienteDireccion { direccion = direccion.Trim() });
                await ClientesService.ActualizarAsync(currentClient);
            }

            // Construir el objeto Pedido
            var nuevoPedido = new Pedido
            {
                cliente = new Cliente { idUsuario = userId.Value },
                fechaPedido = DateTime.Now,
                horaInicio = DateTime.Now,
                horaFin = DateTime.Now.AddHours(1),
                precioTotal = Subtotal,
                precioDelivery = Delivery,
                precioFinal = Total,
                estado = EstadoPedido.PENDIENTE,
                direccionDestino = direccion + (!string.IsNullOrWhiteSpace(referencia) ? $" ({referencia})" : ""),
                detallesProductos = CarritoService.Productos.Select(p => new PedidoDetalleProducto
                {
                    productoSnapshot = new ProductoSnapshot(p.producto),
                    cantidad = p.cantidad
                }).ToList(),
                detallesRecetas = CarritoService.Recetas.Select(r => new PedidoDetalleReceta
                {
                    recetaSnapshot = new RecetaSnapshot(r.receta),
                    cantidad = r.cantidad,
                    descuentoHistorico = r.receta.descuento
                }).ToList()
            };

            // Enviar al backend
            int idPedido = await PedidosService.InsertarAsync(nuevoPedido);

            if (idPedido > 0)
            {
                // Limpiar carrito en frontend
                CarritoService.LimpiarCarrito();
                // Redirigir a la página de éxito
                NavigationManager.NavigateTo($"/order-success/{idPedido}");
            }
            else
            {
                errorMessage = "Hubo un error al procesar el pago. Por favor, intenta de nuevo.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Error de conexión: " + ex.Message;
        }
        finally
        {
            isProcessing = false;
        }
    }
}

@page "/producto/{id:int}"
@using Progra3_Frontend.Model
@using Progra3_Frontend.Services
@inject NavigationManager NavigationManager
@inject ProductosRS ProductosService
@inject CarritoStateService CarritoService
@inject ToastService ToastService
@inject Microsoft.AspNetCore.Components.Authorization.AuthenticationStateProvider AuthStateProvider

<PageTitle>Producto - Allasi Licores</PageTitle>

<div class="product-detail-container">
    @if (producto == null)
    {
        <p>Cargando producto...</p>
    }
    else
    {
        <div class="detail-grid">
            <div class="image-gallery">
                @if (producto.imagenes != null && producto.imagenes.Count > 0)
                {
                    <div class="main-image-container">
                        <button class="nav-btn prev-btn" @onclick="PrevImage"><i class="bi bi-chevron-left"></i></button>
                        <img src="@producto.imagenes[currentImage].url" alt="@producto.nombre" class="main-image" />
                        <button class="nav-btn next-btn" @onclick="NextImage"><i class="bi bi-chevron-right"></i></button>
                    </div>
                    <div class="thumbnails">
                        @foreach (Imagen imagen in producto.imagenes)
                        {
                            <div class="thumbnail @(imagen.id == currentImageId ? "active" : "")" @onclick="()=>SelectImage(imagen.id)">
                                <img src="@imagen.url" alt="@producto.nombre" />
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="main-image-container">
                        <div style="padding: 2rem; text-align: center; color: #666; background: #f9f9f9; border-radius: 8px;">
                            Sin imagen disponible
                        </div>
                    </div>
                }
            </div>

            <div class="product-info">
                <h1 class="product-title">@producto.nombre</h1>
                <p class="product-price">S/. @producto.precioFinal.ToString("0.00")</p>

                <p class="product-description">
                    @(string.IsNullOrEmpty(producto.descripcion) ? "Vino tinto chileno reconocido internacionalmente por su excelente relación calidad-precio. Presenta aromas a frutos rojos maduros y especias suaves con un final agradable y persistente." : producto.descripcion)
                </p>

                <div class="product-specs">
                    <p><strong>Porcentaje de Alcohol:</strong> @producto.porcentajeAlcohol%</p>
                    <p><strong>Volumen:</strong> @producto.volumenLitros Ltrs</p>
                    <p><strong>Descuento disponible:</strong> @(producto.descuento > 0 ? $"{producto.descuento}%" : "Sin descuento")</p>
                    @if (producto.stock <= 0)
                    {
                        <p class="text-danger" style="font-weight: bold;">Estado: Agotado</p>
                    }
                    else
                    {
                        <p><strong>Stock disponible:</strong> @producto.stock</p>
                    }
                </div>

                <div class="add-to-cart-section">
                    <div class="quantity-selector">
                        <button class="qty-btn" @onclick="DecreaseQuantity"><i class="bi bi-dash"></i></button>
                        <input type="text" value="@quantity" readonly />
                        <button class="qty-btn" @onclick="IncreaseQuantity"><i class="bi bi-plus"></i></button>
                    </div>
                    <button class="btn-add-cart" @onclick="AddToCart">
                        <i class="bi bi-cart"></i> Añadir al carrito
                    </button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public int id { get; set; }

    private Producto? producto;
    private List<Imagen> imagenes;
    private int quantity = 1;

    private int currentImage = 0;
    private int? currentImageId = null;



    protected override async Task OnInitializedAsync()
    {
        producto = await ProductosService.ObtenerPorIdAsync(id);
        if (producto == null) return;
        imagenes = producto.imagenes;
        if (imagenes != null && imagenes.Count > 0)
        {
            imagenes.Sort((a, b) => a.principal ? 0 : 1);
            currentImageId = imagenes[0].id;
        }
    }

    private void NextImage()
    {
        if (imagenes == null || imagenes.Count == 0) return;
        currentImage = (currentImage + 1) % imagenes.Count;
        currentImageId = imagenes[currentImage].id;
    }

    private void PrevImage()
    {
        if (imagenes == null || imagenes.Count == 0) return;
        currentImage--;
        if (currentImage < 0)
        {
            currentImage = imagenes.Count - 1;
        }
        currentImageId = imagenes[currentImage].id;
    }

    private void SelectImage(int id)
    {
        for(int i = 0; i < imagenes.Count; i++)
        {
            if(imagenes[i].id == id)
            {
                currentImageId = id;
                currentImage = i;
                break;
            }
        }
    }

    private void DecreaseQuantity()
    {
        if (quantity > 1) quantity--;
    }

    private void IncreaseQuantity()
    {
        if (producto != null && quantity >= producto.stock)
        {
            ToastService.ShowToast("No hay más stock disponible de este producto.", "warning", 1500);
            return;
        }
        quantity++;
    }

    private async Task AddToCart()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity == null || !authState.User.Identity.IsAuthenticated)
        {
            ToastService.ShowToast("No se puede agregar al carrito si no estás registrado.", "warning", 1500);
            return;
        }

        if (producto != null)
        {
            if (producto.stock <= 0)
            {
                ToastService.ShowToast("Este producto se encuentra agotado.", "warning", 1500);
                return;
            }
            
            var itemInCart = CarritoService.Productos.FirstOrDefault(p => p.producto.id == producto.id);
            if (itemInCart != null && (itemInCart.cantidad + quantity) > producto.stock)
            {
                ToastService.ShowToast("No hay suficiente stock para añadir esa cantidad.", "warning", 1500);
                return;
            }

            CarritoService.AgregarProducto(producto, quantity);
        }
    }
}

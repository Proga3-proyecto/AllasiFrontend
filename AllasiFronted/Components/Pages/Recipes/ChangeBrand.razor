@page "/escoger-marca/{IdElemento:int}"

@using Progra3_Frontend.Model
@inject NavigationManager NavigationManager

<div class="change-brand-container">
    <header class="change-brand-header">
        <h1>Escoger otra marca</h1>
        <div class="title-underline"></div>

        <p class="subtitle">Estás cambiando la marca de: <strong>@nombreActual</strong></p>
        <p class="product-type">Tipo: <strong>@Categoria</strong></p>

        <p class="instruction">Selecciona la nueva marca que deseas para este producto:</p>
    </header>

    <main class="brands-grid">
        @if (MarcasAlternativasFiltradas == null || !MarcasAlternativasFiltradas.Any())
        {
            <p class="no-options-alert">No hay marcas alternativas disponibles para esta categoría en este momento.</p>
        }
        else
        {
            @foreach (var opcion in MarcasAlternativasFiltradas)
            {
                <div class="brand-option-card @(MarcaSeleccionada == opcion.nombre ? "active-card" : "")"
                     @onclick="() => SeleccionarMarca(opcion.nombre)">

                    <div class="brand-img-box">
                        <img src="@(opcion.imagenes?.FirstOrDefault()?.url)" alt="@opcion.nombre" class="brand-thumb" />
                    </div>

                    <div class="brand-info">
                        <h3>@opcion.nombre</h3>
                        <p class="brand-category">@(opcion.categorias?.FirstOrDefault()?.nombre)</p>
                        <p class="brand-price">S/ @opcion.precio.ToString("0.00")</p>
                    </div>

                    <div class="brand-radio-wrapper">
                        <div class="custom-radio @(MarcaSeleccionada == opcion.nombre ? "checked" : "")">
                            @if (MarcaSeleccionada == opcion.nombre)
                            {
                                <div class="radio-inner-dot"></div>
                            }
                        </div>
                    </div>
                </div>
            }
        }
    </main>

    <footer class="change-brand-footer">
        <button class="btn-cancel-change" @onclick="Cancelar">Cancelar</button>
        <button class="btn-confirm-change" @onclick="ConfirmarCambio" disabled="@string.IsNullOrEmpty(MarcaSeleccionada)">
            Confirmar cambio
        </button>
    </footer>
</div>

@code {
    // Parámetro obligatorio por Ruta para saber qué registro del carrito se está modificando
    [Parameter] public int IdElemento { get; set; }

    // Parámetros dinámicos leídos desde el QueryString (?categoria=...&nombreActual=...)
    [Parameter][SupplyParameterFromQuery] public string Categoria { get; set; } = string.Empty;
    [Parameter][SupplyParameterFromQuery] public string nombreActual { get; set; } = string.Empty;

    private string MarcaSeleccionada { get; set; } = string.Empty;
    private List<Producto> MarcasAlternativasFiltradas { get; set; } = new();

    // El ciclo OnParametersSet se ejecuta cada vez que los parámetros de la URL cambian
    protected override void OnParametersSet()
    {
        // Decodificamos por seguridad en caso de caracteres especiales o espacios
        Categoria = Uri.UnescapeDataString(Categoria ?? "Pisco");
        nombreActual = Uri.UnescapeDataString(nombreActual ?? "");

        CargarCatalogoPorCategoria(Categoria);

        // Pre-seleccionamos una por defecto si la lista tiene elementos
        if (MarcasAlternativasFiltradas.Any())
        {
            MarcaSeleccionada = MarcasAlternativasFiltradas.First().nombre;
        }
    }

    private void CargarCatalogoPorCategoria(string categoria)
    {
        // Repositorio/Simulación global multi-producto adaptado a tu modelo de datos
        var inventarioMaestro = new List<Producto>
        {
            // --- VARIANTES DE PISCO ---
            new() { nombre = "Santiago Queirolo", categorias = [new Categoria("Pisco")], precio = 25.00, imagenes = [new Imagen("pisco-quebranta.png")] },
            new() { nombre = "Tabernero", categorias = [new Categoria("Pisco")], precio = 26.00, imagenes = [new Imagen("pisco-tabernero.png")] },
            new() { nombre = "Tres Generaciones", categorias = [new Categoria("Pisco")], precio = 24.50, imagenes = [new Imagen("pisco-acholado.png")] },
            new() { nombre = "Biondi", categorias = [new Categoria("Pisco")], precio = 27.00, imagenes = [new Imagen("pisco-biondi.png")] },
            new() { nombre = "Portón", categorias = [new Categoria("Pisco")], precio = 89.00, imagenes = [new Imagen("pisco-porton.png")] },

            // --- VARIANTES DE JARABES / LICORES COMPLEMENTARIOS ---
            new() { nombre = "Jarabe de Goma Burgos", categorias = [new Categoria("Licor")], precio = 15.00, imagenes = [new Imagen("licor-kahlua.png")] },
            new() { nombre = "Jarabe de Goma Caravedo", categorias = [new Categoria("Licor")], precio = 18.50, imagenes = [new Imagen("licor-kahlua.png")] },
            new() { nombre = "Jarabe Premium Monin", categorias = [new Categoria("Licor")], precio = 32.00, imagenes = [new Imagen("licor-kahlua.png")] },

            // --- VARIANTES DE COMPLEMENTOS (Ej: Jugos / Cítricos / Insumos) ---
            new() { nombre = "Jugo de Limón Sutil Del Huerto", categorias = [new Categoria("Complementos")], precio = 8.00, imagenes = [new Imagen("limon.png")] },
            new() { nombre = "Jugo de Limón Premium Frugos", categorias = [new Categoria("Complementos")], precio = 10.50, imagenes = [new Imagen("limon.png")] }
        };

        // Filtrado dinámico inteligente: busca dentro del arreglo de categorías del producto
        MarcasAlternativasFiltradas = inventarioMaestro
            .Where(p => p.categorias != null && p.categorias.Any(c => c.nombre.Equals(categoria, StringComparison.OrdinalIgnoreCase)))
            .ToList();
    }

    private void SeleccionarMarca(string nombreMarca)
    {
        MarcaSeleccionada = nombreMarca;
    }

    private void ConfirmarCambio()
    {
        Console.WriteLine($"ElementoCarrito ID {IdElemento} actualizado con éxito a la marca: {MarcaSeleccionada}");

        // Regresa limpiamente a la pantalla de la receta (corregida la ruta para coincidir con tu componente principal)
        NavigationManager.NavigateTo("/recetas/2/seleccion");
    }

    private void Cancelar()
    {
        NavigationManager.NavigateTo("/recetas/2/seleccion");
    }
}

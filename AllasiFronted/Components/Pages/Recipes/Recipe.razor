@page "/categoria/receta"
@using Progra3_Frontend.Model
@using Progra3_Frontend.Services
@inject RecetasRS RecetaService

<div class="recipes-banner">
    <img src="@BannerImage" class="recipes-banner-img" />
    <div class="recipes-banner-content">
        <h1 class="recipes-title">
            @Titulo
        </h1>
        <div class="products-divider">
            <span></span>
            <i class="fa-light fa-martini-glass"></i>
            <span></span>
        </div>
        <p class="recipes-description">
            @Descripcion
        </p>
    </div>
</div>

<RecibeFilter />

<section class="recipes-section">
    @* <aside class="filters-card">
        <div class="filters-header">
            <h2>FILTROS</h2>
            <i class="bi bi-sliders"></i>
        </div>
        <div class="filter-block">
            <div class="filter-title">
                <span>Buscar receta</span>
            </div>
            <div class="search-input-box">
                <input type="text" placeholder="Ej. Pisco Sour..." @bind="terminoBusqueda" @bind:event="oninput" />
            </div>
        </div>
        <button class="clear-button" @onclick="LimpiarFiltros">
            <i class="bi bi-arrow-counterclockwise"></i>
            Limpiar filtros
        </button>
    </aside> *@

    <main class="recipes-area">
        <div class="products-top">
            <p>Mostrando @RecetasPaginadas.Count de @RecetasFiltradas.Count receta(s)</p>
        </div>

        <div class="recipes-grid">
            @if (Recetas == null)
            {
                <p>Cargando recetas desde el servidor...</p>
            }
            else if (!RecetasFiltradas.Any())
            {
                <p>No se encontraron recetas que coincidan con la búsqueda.</p>
            }
            else
            {
                @* 1. CAMBIAR AL FOREACH PAGINADO *@
                @foreach (var receta in RecetasPaginadas)
                {
                    <RecipeCard receta="receta" />
                }
            }
        </div>

        @* 2. CONTROLES DE PAGINACIÓN *@
        @if (TotalPages > 1)
        {
            <div class="pagination-container">
                <button class="btn-page" disabled="@(currentPage == 1)" @onclick="PaginaAnterior">Anterior</button>

                @for (int i = 1; i <= TotalPages; i++)
                {
                    var numeroPagina = i;
                    <button class="btn-page @(currentPage == numeroPagina ? "active" : "")" @onclick="() => IrAPagina(numeroPagina)">
                        @numeroPagina
                    </button>
                }

                <button class="btn-page" disabled="@(currentPage == TotalPages)" @onclick="PaginaSiguiente">Siguiente</button>
            </div>
        }
    </main>
</section>

@code {
    private string Titulo = "NUESTRAS RECETAS PREMIUM";
    private string Descripcion = "Descubre las mejores combinaciones preparadas por expertos";
    private string BannerImage = "/assets/banner/banner.png";
    
    // Si descomentas la búsqueda en un futuro, un buen extra es que
    // cuando terminoBusqueda cambie, resetees currentPage a 1.
    private string terminoBusqueda = "";

    // --- VARIABLES DE PAGINACIÓN ---
    private int currentPage = 1;
    private int pageSize = 15; // Puedes ajustar cuántas recetas mostrar por página

    private List<Receta> Recetas = new();

    protected override async Task OnInitializedAsync()
    {
        Recetas = await RecetaService.ListarTodosAsync();
    }

    private List<Receta> RecetasFiltradas =>
        Recetas.Where(r => string.IsNullOrWhiteSpace(terminoBusqueda) ||
                           r.nombre.Contains(terminoBusqueda, StringComparison.OrdinalIgnoreCase))
        .ToList();

    // --- LÓGICA DE PAGINACIÓN ---
    private int TotalPages => (int)Math.Ceiling(RecetasFiltradas.Count / (double)pageSize);

    private List<Receta> RecetasPaginadas =>
        RecetasFiltradas
            .Skip((currentPage - 1) * pageSize)
            .Take(pageSize)
            .ToList();

    private void IrAPagina(int page)
    {
        currentPage = page;
    }

    private void PaginaAnterior()
    {
        if (currentPage > 1) currentPage--;
    }

    private void PaginaSiguiente()
    {
        if (currentPage < TotalPages) currentPage++;
    }

    private void LimpiarFiltros()
    {
        terminoBusqueda = "";
        currentPage = 1; // Reiniciar página al limpiar filtros
    }
}

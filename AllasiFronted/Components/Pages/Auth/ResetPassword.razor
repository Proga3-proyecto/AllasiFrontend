@page "/reset-password"
@using AllasiFrontend.Components.Shared.ui
<div class="container">
    <section>
        <div class="form-header">
            <i class="bi bi-shield-lock-fill logo"></i>
            <h1 class="title">
                NUEVA CONTRASEÑA
            </h1>
            <h3 class="sub-title">
                Introduzca y confirme su nueva contraseña.
            </h3>
            <div class="hr"></div>
        </div>
        <form>
            <div class="form-input">
                <label for="password">
                    Nueva contraseña
                </label>
                <div class="input-container">
                    <i class="bi bi-lock-fill"></i>
                    <input id="password"
                           @bind="password" @bind:event="oninput"
                           type="@(hidePassword ? "password" : "text")"
                           placeholder="*************" style="border:none; outline:none; background:transparent; width:100%; padding-left:10px;" />
                    <div @onclick="TogglePassword" style="cursor: pointer; padding-right:10px;">
                        @if (hidePassword)
                        {
                            <i class="bi bi-eye-slash"></i>
                        }
                        else
                        {
                            <i class="bi bi-eye"></i>
                        }
                    </div>
                </div>
                
                <div class="mt-2" style="width: 100%;">
                    <IndicatorBar Color="@strengthColor" State="@strengthText" Percent="@strengthPercent" Label="Seguridad" />
                </div>
                
                <div class="requirements-box mt-2 p-2 bg-light" style="border-radius: 8px; width: 100%; margin-bottom: 15px;">
                    <div class="row g-1" style="font-size: 0.75rem;">
                        <div class="col-sm-6">
                            <i class="bi @(hasMinLength ? "bi-check-circle-fill text-success" : "bi-x-circle text-danger") me-1"></i> Mínimo 8 caracteres
                        </div>
                        <div class="col-sm-6">
                            <i class="bi @(hasNumber ? "bi-check-circle-fill text-success" : "bi-x-circle text-danger") me-1"></i> Al menos un número
                        </div>
                        <div class="col-sm-6">
                            <i class="bi @(hasUpper ? "bi-check-circle-fill text-success" : "bi-x-circle text-danger") me-1"></i> Al menos una mayúscula
                        </div>
                        <div class="col-sm-6">
                            <i class="bi @(hasSpecial ? "bi-check-circle-fill text-success" : "bi-x-circle text-danger") me-1"></i> Al menos un carácter especial
                        </div>
                    </div>
                </div>
            </div>
            <div class="form-input">
                <label for="confirmPassword">
                    Confirmar contraseña
                </label>
                <div class="input-container">
                    <i class="bi bi-lock-fill"></i>
                    <input id="confirmPassword"
                           type="@(hideConfirmPassword ? "password" : "text")"
                           placeholder="*************" />
                    <div @onclick="ToggleConfirmPassword">
                        @if (hideConfirmPassword)
                        {
                            <i class="bi bi-eye-slash"></i>
                        }
                        else
                        {
                            <i class="bi bi-eye"></i>
                        }
                    </div>
                </div>
            </div>
            <button type="submit">
                Cambiar contraseña
            </button>
        </form>
        <div>
            <a href="/login" class="link">
                Volver al inicio de sesión
            </a>
        </div>
    </section>
</div>
@code {
    private bool hidePassword = true;
    private bool hideConfirmPassword = true;
    private string password = "";

    private void TogglePassword()
    {
        hidePassword = !hidePassword;
    }

    private void ToggleConfirmPassword()
    {
        hideConfirmPassword = !hideConfirmPassword;
    }

    private string PasswordToCheck => password;
    private bool hasMinLength => (PasswordToCheck?.Length >= 8);
    private bool hasNumber => !string.IsNullOrEmpty(PasswordToCheck) && PasswordToCheck.Any(char.IsDigit);
    private bool hasUpper => !string.IsNullOrEmpty(PasswordToCheck) && PasswordToCheck.Any(char.IsUpper);
    private bool hasSpecial => !string.IsNullOrEmpty(PasswordToCheck) && PasswordToCheck.Any(c => !char.IsLetterOrDigit(c));

    private int PasswordScore
    {
        get
        {
            if (string.IsNullOrEmpty(PasswordToCheck)) return 0;
            int score = 0;
            if (hasMinLength) score++;
            if (hasNumber) score++;
            if (hasUpper) score++;
            if (hasSpecial) score++;
            return score;
        }
    }

    private string strengthText => PasswordScore switch
    {
        4 => "Fuerte",
        3 => "Media",
        2 => "Media",
        _ => "Débil"
    };

    private string strengthColor => PasswordScore switch
    {
        4 => "#198754", 
        3 => "#ffc107", 
        2 => "#ffc107", 
        _ => "#dc3545"  
    };

    private int strengthPercent => PasswordScore switch
    {
        4 => 100,
        3 => 75,
        2 => 50,
        1 => 25,
        _ => 15
    };
}

@page "/underage"
@inject NavigationManager Navigation

<div class="container d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="text-center p-5" style="background-color: white; border-radius: 16px; box-shadow: 0 10px 30px rgba(0,0,0,0.1); max-width: 500px;">
        <div class="mb-4" style="color: #ef4444; font-size: 4rem;">
            <i class="bi bi-shield-lock-fill"></i>
        </div>
        
        <h2 class="fw-bold text-dark mb-3">Acceso Restringido</h2>
        
        <p class="text-muted mb-4" style="font-size: 1.1rem;">
            Lo sentimos, debes ser <strong>mayor de edad</strong> para poder registrarte y utilizar nuestra plataforma. 
            Esta medida es necesaria para cumplir con las regulaciones de venta.
        </p>
        
        <button class="btn text-white w-100 py-2 rounded-3 fw-bold" 
                style="background-color: #0f172a; transition: opacity 0.2s;"
                @onclick='() => Navigation.NavigateTo("/")'
                onmouseover="this.style.opacity='0.8'" 
                onmouseout="this.style.opacity='1'">
            Volver al Inicio
        </button>
    </div>
</div>

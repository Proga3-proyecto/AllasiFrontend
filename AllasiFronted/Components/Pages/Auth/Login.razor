@page "/login"
@using Progra3_Frontend.Models
@using Progra3_Frontend.Services
@using Progra3_Frontend.Services.Auth

@inject IAuthService AuthService
@inject NavigationManager Navigation
@inject CustomAuthenticationStateProvider AuthProvider

<div class="container">
    <section>
        <div class="form-header">
            <i class="bi bi-person-lock logo"></i>
            <h1 class="title">
                INICIO DE SESIÓN
            </h1>
            <h3 class="sub-title">
                Introduzca su correo electrónico y contraseña:
            </h3>
            <div class="hr"></div>
        </div>

        <form @onsubmit="OnSumit">
            <div class="form-input">
                <label for="email">Correo electrónico</label>
                <div class="input-container">
                    <i class="bi bi-envelope"></i>
                    <input id="email"
                           @bind="login.Usuario"
                           placeholder="ejemplo@correo.com"
                           type="email" />
                </div>
            </div>

            <div class="form-input">
                <label for="password">Contraseña</label>
                <div class="input-container">
                    <i class="bi bi-lock-fill"></i>
                    <input id="password"
                           @bind="login.Password"
                           type="@(hidePassword ? "password" : "text")"
                           placeholder="*************" />
                    <div @onclick="changeVisibility" style="cursor:pointer;">
                        @if (hidePassword)
                        {
                            <i class="bi bi-eye-slash"></i>
                        }
                        else
                        {
                            <i class="bi bi-eye"></i>
                        }
                    </div>
                </div>
            </div>

            <a href="/forgot-password" class="link">
                <u>¿Olvidaste tu contraseña?</u>
            </a>
            @if (!string.IsNullOrEmpty(error))
            {
                <div class="alert alert-danger" style="color: red; margin-bottom: 15px;">
                    @error
                </div>
            }

            @if (isProcessing)
            {
                <button type="button" disabled style="opacity: 0.7; cursor: not-allowed;">
                    <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true" style="margin-right: 8px;"></span>
                    Ingresando...
                </button>
            }
            else
            {
                <button type="submit">Ingresar</button>
            }
        </form>

        <div class="footer-register">
            <span class="label">¿Eres nuevo?</span>
            <a href="/register" class="link"><u>Crear una cuenta</u></a>
        </div>
    </section>
</div>

@code {
    private LoginRequest login = new();

    private string error = "";

    bool hidePassword = true;
    private bool isProcessing = false;

    void changeVisibility()
    {
        hidePassword = !hidePassword;
    }

    async Task OnSumit()
    {
        if (isProcessing) return;
        isProcessing = true;
        error = "";

        try
        {
            var usuario =
                await AuthService.Login(login);

            if (usuario == null)
            {
                error =
                    "No se pudo conectar con el servidor";

                return;
            }

            if (usuario.Exito)
            {
                await AuthProvider.Login(
                    usuario.IdUsuario,
                    usuario.Nombre,
                    usuario.Rol);

                string userRole = usuario.Rol?.Trim().ToUpper();
                if (userRole == "ADMIN" || userRole == "MASTER")
                {
                    Navigation.NavigateTo("/admin");
                }
                else
                {
                    Navigation.NavigateTo("/");
                }
            }

            if (!usuario.Exito)
            {
                error = usuario.Mensaje;

                return;
            }
        }
        finally
        {
            isProcessing = false;
        }
    }
}


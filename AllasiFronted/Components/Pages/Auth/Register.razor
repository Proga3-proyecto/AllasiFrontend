@page "/register"
@using System.ComponentModel.DataAnnotations
@using Progra3_Frontend.Model
@using Progra3_Frontend.Services
@using Progra3_Frontend.Services.Auth
@using AllasiFrontend.Components.Shared.ui
@inject NavigationManager Navigation
@inject ClientesRS clienteRS
@inject CustomAuthenticationStateProvider AuthProvider
@inject ConfirmDialogService DialogService

<div class="container">
    <section>
        <div class="form-header">
            <h1 class="title">
                CREAR CUENTA
            </h1>
            <h3 class="sub-title">
                Completa tus datos para crear tu cuenta.
            </h3>
            <div class="hr"></div>
        </div>

        <EditForm Model="formUser" OnValidSubmit="CrearCuenta" class="form-body">
            <DataAnnotationsValidator />
            
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger" style="color: red; margin-bottom: 15px; font-weight: bold;" role="alert">
                    @errorMessage
                </div>
            }

            <div class="register-container">
                <div class="left-column">
                    <div class="form-input">
                        <label>Nombre(s)</label>
                        <div class="input-container">
                            <i class="bi bi-person"></i>
                            <InputText @bind-Value="formUser.Nombres" placeholder="Ingresa tu nombre" />
                        </div>
                        <ValidationMessage For="@(() => formUser.Nombres)" />
                    </div>

                    <div class="double-row">
                        <div class="form-input">
                            <label>Apellido Paterno</label>
                            <div class="input-container">
                                <i class="bi bi-person"></i>
                                <InputText @bind-Value="formUser.ApellidoPaterno" placeholder="Apellido paterno" />
                            </div>
                            <ValidationMessage For="@(() => formUser.ApellidoPaterno)" />
                        </div>

                        <div class="form-input">
                            <label>Apellido Materno</label>
                            <div class="input-container">
                                <i class="bi bi-person"></i>
                                <InputText @bind-Value="formUser.ApellidoMaterno" placeholder="Apellido materno" />
                            </div>
                            <ValidationMessage For="@(() => formUser.ApellidoMaterno)" />
                        </div>
                    </div>

                    <div class="form-input">
                        <label>Correo electrónico</label>
                        <div class="input-container">
                            <i class="bi bi-envelope"></i>
                            <InputText @bind-Value="formUser.Email" placeholder="ejemplo@correo.com" />
                        </div>
                        <ValidationMessage For="@(() => formUser.Email)" />
                    </div>

                    <div class="form-input">
                        <label>Contraseña</label>
                        <div class="input-container" style="position: relative;">
                            <i class="bi bi-lock-fill"></i>
                            <input @bind-Value="formUser.Password" @bind-Value:event="oninput" type="@(showPassword ? "text" : "password")" placeholder="Crea una contraseña" style="padding-right: 35px; width: 100%;" />
                            <i class="bi @(showPassword ? "bi-eye-slash" : "bi-eye") text-muted" style="position: absolute; right: 15px; cursor: pointer;" @onclick="() => showPassword = !showPassword"></i>
                        </div>
                        <ValidationMessage For="@(() => formUser.Password)" />
                        
                        <div class="password-strength-container">
                            <div class="password-strength-bars">
                                <div class="strength-bar @GetStrengthBarClass(1)"></div>
                                <div class="strength-bar @GetStrengthBarClass(2)"></div>
                                <div class="strength-bar @GetStrengthBarClass(3)"></div>
                                <div class="strength-bar @GetStrengthBarClass(4)"></div>
                                <div class="strength-bar @GetStrengthBarClass(5)"></div>
                            </div>
                            <span class="strength-text @GetStrengthTextClass()">@GetStrengthText()</span>
                        </div>
                    </div>

                    <div class="form-input">
                        <label>Repetir Contraseña</label>
                        <div class="input-container" style="position: relative;">
                            <i class="bi bi-lock-fill"></i>
                            <InputText @bind-Value="formUser.ConfirmPassword" type="@(showConfirmPassword ? "text" : "password")" placeholder="Repite tu contraseña" style="padding-right: 35px; width: 100%;" />
                            <i class="bi @(showConfirmPassword ? "bi-eye-slash" : "bi-eye") text-muted" style="position: absolute; right: 15px; cursor: pointer;" @onclick="() => showConfirmPassword = !showConfirmPassword"></i>
                        </div>
                        <ValidationMessage For="@(() => formUser.ConfirmPassword)" />
                    </div>
                </div>

                <div class="right-column">
                    <div class="form-input">
                        <label>DNI</label>
                        <div class="input-container">
                            <i class="bi bi-person-vcard"></i>
                            <InputText @bind-Value="formUser.Dni" placeholder="Ingresa tu DNI" maxlength="8" />
                        </div>
                        <ValidationMessage For="@(() => formUser.Dni)" />
                    </div>

                    <div class="form-input">
                        <label>Teléfono</label>
                        <div class="input-container">
                            <i class="bi bi-telephone"></i>
                            <InputText @bind-Value="formUser.Telefono" placeholder="Ingresa tu teléfono" maxlength="9" />
                        </div>
                        <ValidationMessage For="@(() => formUser.Telefono)" />
                    </div>

                    <div class="form-input">
                        <label>Fecha de Nacimiento</label>
                        <div class="input-container">
                            <i class="bi bi-calendar3"></i>
                            <InputDate @bind-Value="formUser.FechaNacimiento" />
                        </div>
                        <ValidationMessage For="@(() => formUser.FechaNacimiento)" />
                    </div>
                </div>
            </div>

            @if (isProcessing)
            {
                <button type="button" class="register-button" disabled style="opacity: 0.7; cursor: not-allowed;">
                    <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true" style="margin-right: 8px;"></span>
                    Creando Cuenta...
                </button>
            }
            else
            {
                <button type="submit" class="register-button">
                    Crear Cuenta
                </button>
            }

            <div class="footer-link">
                <span class="label">¿Ya tienes cuenta?</span>
                <a href="/login" class="link"><u>Iniciar sesión</u></a>
            </div>
        </EditForm>
    </section>
</div>

@code {
    private RegistroUsuario formUser = new();
    
    private string? errorMessage;
    private bool isProcessing = false;
    private bool showPassword = false;
    private bool showConfirmPassword = false;

    private int PasswordScore => CalculatePasswordScore(formUser.Password);

    private int CalculatePasswordScore(string? password)
    {
        if (string.IsNullOrEmpty(password)) return 0;
        int score = 0;
        if (password.Length >= 8) score++;
        if (password.Any(char.IsUpper)) score++;
        if (password.Any(char.IsLower)) score++;
        if (password.Any(char.IsDigit)) score++;
        if (password.Any(ch => !char.IsLetterOrDigit(ch))) score++;
        return score;
    }

    private string GetStrengthBarClass(int barIndex)
    {
        var score = PasswordScore;
        if (barIndex > score) return "";

        return score switch
        {
            1 => "weak",
            2 => "fair",
            3 => "good",
            4 => "strong",
            5 => "very-strong",
            _ => ""
        };
    }

    private string GetStrengthTextClass()
    {
        return PasswordScore switch
        {
            0 => "text-empty",
            1 => "text-weak",
            2 => "text-fair",
            3 => "text-good",
            4 => "text-strong",
            5 => "text-very-strong",
            _ => "text-empty"
        };
    }

    private string GetStrengthText()
    {
        return PasswordScore switch
        {
            0 => "Nivel de seguridad",
            1 => "Muy Débil",
            2 => "Débil",
            3 => "Aceptable",
            4 => "Fuerte",
            5 => "Muy Fuerte",
            _ => ""
        };
    }

    private async Task CrearCuenta()
    {
        if (isProcessing) return;
       if (PasswordScore < 4) 
    {
        errorMessage = "La contraseña no cumple con todos los requisitos de seguridad.";
        return;
    }
        isProcessing = true;
        errorMessage = null;

        try
        {
            bool esMayor = await DialogService.ConfirmAsync("Verificación de edad", "¿Confirmas ser mayor de edad?", DialogType.Info);
            if (!esMayor)
            {
                Navigation.NavigateTo("/underage");
                return;
            }

            Cliente cliente = new();
        cliente.dni = formUser.Dni;
        cliente.correo = formUser.Email;
        cliente.nombre = formUser.Nombres;
        cliente.apellidoCompleto = formUser.ApellidoPaterno + " " + formUser.ApellidoMaterno;
        cliente.contrasenaHash = formUser.Password; //TODO: Encriptar mensaje
        cliente.fechaNacimiento = formUser.FechaNacimiento;
        cliente.telefono = formUser.Telefono; 
        
        Cliente? nuevoCliente = await clienteRS.InsertarAsync(cliente);

        if (nuevoCliente == null)
        {
            errorMessage = "Hubo un problema al crear la cuenta. Verifica tus datos o intenta más tarde.";
        }
        else
        {
            await AuthProvider.Login(
                nuevoCliente.idUsuario,
                nuevoCliente.nombre,
                "CLIENTE"
            );
            Navigation.NavigateTo("/");
        }
        }
        finally
        {
            isProcessing = false;
        }
    }

    public class RegistroUsuario
    {
        [Required(ErrorMessage = "El nombre es obligatorio")]
        [MinLength(2)]
        public string Nombres { get; set; } = "";

        [Required(ErrorMessage = "El apellido paterno es obligatorio")]
        public string ApellidoPaterno { get; set; } = "";

        [Required(ErrorMessage = "El apellido materno es obligatorio")]
        public string ApellidoMaterno { get; set; } = "";

        [Required(ErrorMessage = "El DNI es obligatorio")]
        [RegularExpression(@"^\d{8}$", ErrorMessage = "El DNI debe contener exactamente 8 dígitos")]
        public string Dni { get; set; } = "";

        [Required(ErrorMessage = "El teléfono es obligatorio")]
        [RegularExpression(@"^\d{9}$", ErrorMessage = "El teléfono debe contener exactamente 9 dígitos")]
        public string Telefono { get; set; } = "";

        [Required(ErrorMessage = "El correo es obligatorio")]
        [EmailAddress(ErrorMessage = "Correo inválido")]
        public string Email { get; set; } = "";

        [Required(ErrorMessage = "Debe ingresar una contraseña")]
        [MinLength(8, ErrorMessage = "La contraseña debe tener mínimo 8 caracteres")]
        [ContrasenaFuerte(ErrorMessage = "La contraseña debe ser más segura (mínimo nivel fuerte). Usa mayúsculas, números o símbolos.")]
        public string Password { get; set; } = "";

        [Required(ErrorMessage = "Debe repetir la contraseña")]
        [Compare(nameof(Password), ErrorMessage = "Las contraseñas no coinciden")]
        public string ConfirmPassword { get; set; } = "";

        [Required(ErrorMessage = "Seleccione una fecha")]
        [MayorDeEdad(ErrorMessage = "Debe ingresar una fecha de nacimiento mayor a 18 años.")]
        public DateTime? FechaNacimiento { get; set; }
    }

    public class MayorDeEdadAttribute : ValidationAttribute
    {
        protected override ValidationResult? IsValid(object? value, ValidationContext validationContext)
        {
            if (value is DateTime fechaNac)
            {
                var edad = DateTime.Today.Year - fechaNac.Year;
                if (fechaNac.Date > DateTime.Today.AddYears(-edad)) edad--;
                if (edad < 18)
                {
                    return new ValidationResult(ErrorMessage ?? "Debe ser mayor de edad.");
                }
            }
            return ValidationResult.Success;
        }
    }

    public class ContrasenaFuerteAttribute : ValidationAttribute
    {
        protected override ValidationResult? IsValid(object? value, ValidationContext validationContext)
        {
            if (value is string password)
            {
                int score = 0;
                if (password.Length >= 8) score++;
                if (password.Any(char.IsUpper)) score++;
                if (password.Any(char.IsLower)) score++;
                if (password.Any(char.IsDigit)) score++;
                if (password.Any(ch => !char.IsLetterOrDigit(ch))) score++;

                if (score < 4)
                {
                    return new ValidationResult(ErrorMessage ?? "La contraseña debe ser más segura (nivel fuerte).");
                }
            }
            return ValidationResult.Success;
        }
    }
}

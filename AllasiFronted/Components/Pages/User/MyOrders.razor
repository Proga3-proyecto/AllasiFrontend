@page "/user/my-orders"
@using Progra3_Frontend.Model
@using Progra3_Frontend.Services
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@inject ClientesRS ClientesService
@inject AuthenticationStateProvider AuthStateProvider
@layout UserLayout

<div class="orders-page-container">

    <div class="text-center mb-4">
        <h2 class="fw-bold text-navy mb-1" style="font-size: 1.35rem;">Mis pedidos</h2>
        <p class="text-muted mb-2" style="font-size: 0.85rem;">Revisa el estado de tus pedidos y su historial.</p>
    </div>

    <div class="tabs mb-3">
        <span class="tab-activo pb-2 d-inline-block">Todos</span>
    </div>

    <div class="pedido-card">
        @if (isLoading)
        {
            <div class="text-center py-5 text-muted">
                <div class="d-flex flex-column align-items-center justify-content-center">
                    <span class="spinner-border text-navy mb-2" role="status" aria-hidden="true" style="width: 2rem; height: 2rem;"></span>
                    <span>Cargando pedidos...</span>
                </div>
            </div>
        }
        else if (pedidos == null || !pedidos.Any())
        {
            <div class="text-center">
                <p>No tienes pedidos registrados.</p>
            </div>
        }
        else
        {
            @foreach (var pedido in pedidos)
            {
                <div class="pedido-item">
                    <div class="pedido-col">
                        <h3 class="text-navy fw-bold">Pedido #@pedido.id</h3>
                        <p class="text-muted">@(pedido.fechaPedido?.ToString("dd MMM. yyyy - hh:mm tt") ?? "")</p>
                        <a href="/user/order-details/@pedido.id" class="detalle-link">Ver detalle</a>
                    </div>

                    <div class="pedido-col">
                        <label>Total</label>
                        <h3 class="text-dark fw-bold">S/ @pedido.precioFinal.ToString("0.00")</h3>
                        <p class="text-muted">Monto total</p>
                    </div>

                    <div class="pedido-col">
                        <label>Estado</label>
                        <span class="estado @GetEstadoClass(pedido.estado)">@pedido.estado</span>
                    </div>

                    <div class="pedido-col">
                        <label>Fecha Estimada</label>
                        <h3 class="text-dark fw-bold">
                            @if(pedido.horaInicio.HasValue) 
                            {
                                @pedido.horaInicio.Value.ToString("dd MMM. yyyy")
                            }
                            else 
                            {
                                @("Por confirmar")
                            }
                        </h3>
                    </div>
                </div>
            }
        }

        <p class="security-footer-text mt-4">
            <img src="assets/icons/escudo.png" alt="Seguro" class="footer-shield-icon-img" /> Tu información está segura con nosotros y no será compartida con terceros.
        </p>
    </div>
</div>

@code {
    private List<Pedido>? pedidos;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        
        if (user.Identity != null && user.Identity.IsAuthenticated)
        {
            var userIdClaim = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            
            if (int.TryParse(userIdClaim, out int userId))
            {
                pedidos = await ClientesService.ObtenerPedidosPasadosAsync(userId);
                
                if (pedidos != null)
                {
                    pedidos = pedidos.OrderByDescending(p => p.fechaPedido).ToList();
                }
            }
        }
        
        isLoading = false;
    }

    private string GetEstadoClass(EstadoPedido estado)
    {
        return estado switch
        {
            EstadoPedido.PENDIENTE => "proceso",
            EstadoPedido.EN_PREPARACION => "proceso",
            EstadoPedido.EN_CAMINO => "enviado",
            EstadoPedido.ENTREGADO => "entregado",
            EstadoPedido.CANCELADO => "proceso", 
            EstadoPedido.RECHAZADO => "proceso",
            _ => "proceso"
        };
    }
}

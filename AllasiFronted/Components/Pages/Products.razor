@page "/products/{category}"
@page "/recetas"
@using AllasiFrontend.Components.Shared
@using Progra3_Frontend.Model
@using Progra3_Frontend.Services
@inject NavigationManager NavigationManager
@inject ProductosRS ProductosService
@inject RecetasRS RecetasService

<PageTitle>@(isRecetasPage ? "Recetas" : (!string.IsNullOrWhiteSpace(SearchQuery) ? "Búsqueda" : "Productos")) - Allasi Licores</PageTitle>

<div class="products-page">
    <div class="category-banner">
        <div class="banner-content">
            <h1 class="banner-title">@(isRecetasPage ? "RECETAS" : (!string.IsNullOrWhiteSpace(SearchQuery) ? "BÚSQUEDA" : category?.ToUpper()))</h1>
            <div class="banner-separator">
                <span class="line"></span>
                <i class="bi bi-cup-straw banner-icon"></i>
                <span class="line"></span>
            </div>
            <p class="banner-subtitle">
                @(isRecetasPage ? "Explora las mejores preparaciones para tus licores" : (!string.IsNullOrWhiteSpace(SearchQuery) ? $"Resultados para \"{SearchQuery}\"" : "Explora los mejores productos de esta categoría"))
            </p>
        </div>
    </div>

    <div class="products-container">
        <aside class="products-sidebar">
            <div class="filter-card">
                <div class="filter-header">
                    <h3>FILTROS</h3>
                    <i class="bi bi-sliders"></i>
                </div>
                
                <div class="filter-section">
                    <div class="filter-section-header" @onclick="TogglePrice">
                        <h4>Rango de precio</h4>
                        <i class="bi @(isPriceOpen ? "bi-chevron-up" : "bi-chevron-down")"></i>
                    </div>
                    @if (isPriceOpen)
                    {
                        <div class="filter-section-content">
                            <div class="price-inputs">
                                <input type="number" placeholder="S/ Min" @bind="minPrice" @bind:event="oninput" @onkeyup="ApplyFilters" />
                                <input type="number" placeholder="S/ Max" @bind="maxPrice" @bind:event="oninput" @onkeyup="ApplyFilters" />
                            </div>
                        </div>
                    }
                </div>

                @if (!isRecetasPage && availableBrands.Any())
                {
                    <div class="filter-section">
                        <div class="filter-section-header" @onclick="ToggleBrand">
                            <h4>Marca</h4>
                            <i class="bi @(isBrandOpen ? "bi-chevron-up" : "bi-chevron-down")"></i>
                        </div>
                        @if (isBrandOpen)
                        {
                            <div class="filter-section-content brand-list-container">
                                @foreach (var brand in availableBrands)
                                {
                                    <div class="brand-option">
                                        <input type="checkbox" id="brand_@brand" checked="@selectedBrands.Contains(brand)" @onchange="@(e => ToggleBrandSelection(brand, e.Value))" />
                                        <label for="brand_@brand">@brand</label>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }

                <button class="btn-clear-filters" @onclick="ClearFilters">
                    <i class="bi bi-arrow-counterclockwise"></i> limpiar filtros
                </button>
            </div>
        </aside>

        <main class="products-main">
            <div class="products-status">
                <p>Mostrando @(TotalFilteredItems == 0 ? 0 : (currentPage - 1) * pageSize + 1) al @Math.Min(currentPage * pageSize, TotalFilteredItems) de @TotalFilteredItems @(isRecetasPage ? "receta(s)" : (isAllProducts ? "resultado(s)" : "producto(s)"))</p>
            </div>
            
            <div class="products-grid">
                @if (isLoading)
                {
                    <p>Cargando...</p>
                }
                else if (!PagedItems.Any())
                {
                    <p>No se encontraron resultados.</p>
                }
                else
                {
                    foreach (var item in PagedItems)
                    {
                        if (item is Producto p)
                        {
                            <ProductCard ProductoItem="@p" />
                        }
                        else if (item is Receta r)
                        {
                            <ProductCard RecetaItem="@r" />
                        }
                    }
                }
            </div>

            @if (TotalPages > 1)
            {
                <div class="pagination">
                    <button class="btn-page" disabled="@(currentPage == 1)" @onclick="PreviousPage">Anterior</button>
                    @for (int i = 1; i <= TotalPages; i++)
                    {
                        var pageNumber = i;
                        <button class="btn-page @(currentPage == pageNumber ? "active" : "")" @onclick="() => GoToPage(pageNumber)">
                            @pageNumber
                        </button>
                    }
                    <button class="btn-page" disabled="@(currentPage == TotalPages)" @onclick="NextPage">Siguiente</button>
                </div>
            }
        </main>
    </div>
</div>

@code {
    [Parameter]
    public string category { get; set; } = "GIN";

    [Parameter]
    [SupplyParameterFromQuery(Name = "search")]
    public string? SearchQuery { get; set; }

    private bool isPriceOpen = true;
    private bool isBrandOpen = false;
    private bool isRecetasPage => NavigationManager.Uri.Contains("/recetas", StringComparison.OrdinalIgnoreCase);
    private bool isAllProducts => string.Equals(category, "all", StringComparison.OrdinalIgnoreCase) || string.IsNullOrEmpty(category);

    private List<Producto> productos = new();
    private List<Producto> filteredProductos = new();
    private List<Receta> recetas = new();
    private List<Receta> filteredRecetas = new();
    private bool isLoading = true;

    // Filters
    private double? minPrice;
    private double? maxPrice;
    private List<string> availableBrands = new();
    private HashSet<string> selectedBrands = new();

    // Pagination
    private int currentPage = 1;
    private int pageSize = 12; // 4 columns * 3 rows

    private int TotalFilteredItems => filteredProductos.Count + filteredRecetas.Count;
    private int TotalPages => (int)Math.Ceiling((double)TotalFilteredItems / pageSize);

    private IEnumerable<object> PagedItems
    {
        get
        {
            var allItems = filteredProductos.Cast<object>().Concat(filteredRecetas.Cast<object>());
            return allItems.Skip((currentPage - 1) * pageSize).Take(pageSize);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        isLoading = true;
        ClearFiltersInternal();

        productos.Clear();
        recetas = new();

        if (isRecetasPage)
        {
            recetas = await RecetasService.ListarTodosAsync() ?? new List<Receta>();
        }
        else
        {
            var todosProductos = await ProductosService.ListarTodosAsync() ?? new List<Producto>();
            if (isAllProducts)
            {
                productos = todosProductos.ToList();
                recetas = await RecetasService.ListarTodosAsync() ?? new List<Receta>();
            }
            else
            {
                productos = todosProductos.Where(p => p.categorias != null && p.categorias.Any(c => c.nombre != null && c.nombre.Equals(category, StringComparison.OrdinalIgnoreCase))).ToList();
            }
            
            // Extract available brands from products
            availableBrands = productos
                .Where(p => p.marca != null && !string.IsNullOrWhiteSpace(p.marca.nombre))
                .Select(p => p.marca.nombre)
                .Distinct()
                .OrderBy(m => m)
                .ToList();
        }
        
        ApplyFilters();
        isLoading = false;
    }

    private void ApplyFilters()
    {
        // No filtrar recetas por precio o marca
        filteredRecetas = recetas.Where(r => (
            string.IsNullOrWhiteSpace(SearchQuery) || 
            (r.nombre != null && r.nombre.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase)) ||
            (r.descripcion != null && r.descripcion.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase)))
            && (!minPrice.HasValue || r.precio >= minPrice.Value) &&
            (!maxPrice.HasValue || r.precio <= maxPrice.Value)
        ).ToList();

        filteredProductos = productos.Where(p => 
            (!minPrice.HasValue || p.precio >= minPrice.Value) &&
            (!maxPrice.HasValue || p.precio <= maxPrice.Value) &&
            (selectedBrands.Count == 0 || (p.marca != null && selectedBrands.Contains(p.marca.nombre))) &&
            (string.IsNullOrWhiteSpace(SearchQuery) || 
             (p.nombre != null && p.nombre.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase)) ||
             (p.descripcion != null && p.descripcion.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase)) ||
             (p.marca != null && p.marca.nombre != null && p.marca.nombre.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase)))
        ).ToList();
        
        currentPage = 1; // Reset to first page when filtering
    }

    private void ToggleBrandSelection(string brand, object? isChecked)
    {
        bool isSelected = isChecked is bool b ? b : false;
        
        if (isSelected)
            selectedBrands.Add(brand);
        else
            selectedBrands.Remove(brand);
            
        ApplyFilters();
    }

    private void ClearFilters()
    {
        ClearFiltersInternal();
        ApplyFilters();
    }

    private void ClearFiltersInternal()
    {
        minPrice = null;
        maxPrice = null;
        selectedBrands.Clear();
    }

    private void PreviousPage()
    {
        if (currentPage > 1) currentPage--;
    }

    private void NextPage()
    {
        if (currentPage < TotalPages) currentPage++;
    }

    private void GoToPage(int page)
    {
        if (page >= 1 && page <= TotalPages) currentPage = page;
    }

    private void TogglePrice() => isPriceOpen = !isPriceOpen;
    private void ToggleBrand() => isBrandOpen = !isBrandOpen;
}

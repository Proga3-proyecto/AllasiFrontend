@page "/admin/order-list"
@using Microsoft.AspNetCore.Components.Authorization
@layout AdminLayout

@using Progra3_Frontend.Model
@using Progra3_Frontend.Services

@inject PedidosRS PedidosRS
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthenticationStateProvider

<AuthorizeView Roles="ADMIN, MASTER" Context="authContext">
    <Authorized>
        <div class="container-fluid mt-3" style="max-width: 1400px;">

            <div class="d-flex justify-content-between align-items-center mb-3">
                <h2 class="fw-bold text-navy mb-0 main-title">Pedidos de la Tienda</h2>
            </div>

            <div class="table-container shadow-sm">

                <div class="row g-3 mb-4 align-items-end">
                    <div class="col-md-3">
                        <label class="form-label-custom text-muted mb-1" style="font-size: 0.85rem;">Estado</label>
                        <select class="form-select custom-input" @bind="InputEstado">
                            <option value="Todos">Todos</option>
                            @foreach (var estado in Enum.GetValues(typeof(EstadoPedido)))
                            {
                                <option value="@estado">@estado</option>
                            }
                        </select>
                    </div>

                    <div class="col-md-3">
                        <label class="form-label-custom text-muted mb-1" style="font-size: 0.85rem;">Cliente</label>
                        <div class="position-relative">
                            <input type="text" class="form-control custom-input pe-5" placeholder="Buscar cliente..." @bind="InputCliente" />
                            <i class="bi bi-search position-absolute" style="top: 50%; right: 12px; transform: translateY(-50%); color: #94a3b8;"></i>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label-custom text-muted mb-1" style="font-size: 0.85rem;">Fecha (Desde - Hasta)</label>
                        <div class="d-flex gap-2">
                            <input type="date" class="form-control custom-input" @bind="InputFechaDesde" title="Fecha Desde" />
                            <input type="date" class="form-control custom-input" @bind="InputFechaHasta" title="Fecha Hasta" />
                        </div>
                    </div>

                    <div class="col-md-2 d-flex gap-2">
                        <button class="btn navy-bg px-3 py-2 flex-grow-1 d-flex align-items-center justify-content-center gap-2" style="border-radius: 6px; font-weight: 500;" @onclick="AplicarFiltros">
                            <i class="bi bi-funnel"></i> Filtrar
                        </button>
                        <button class="btn btn-outline-custom px-3 py-2 flex-grow-1 d-flex align-items-center justify-content-center gap-2" style="border-radius: 6px; font-weight: 500;" @onclick="LimpiarFiltros">
                            <i class="bi bi-arrow-clockwise"></i> Limpiar
                        </button>
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="table custom-table table-borderless align-middle w-100">
                        <thead class="text-start">
                            <tr>
                                <th scope="col" class="px-2" style="width: 10%;">ID PEDIDO</th>
                                <th scope="col" style="width: 25%;">CLIENTE</th>
                                <th scope="col" style="width: 20%;">FECHA Y HORA</th>
                                <th scope="col" style="width: 15%;">ESTADO</th>
                                <th scope="col" style="width: 15%;">TOTAL (S/.)</th>
                                <th scope="col" class="text-center" style="width: 15%;">ACCIONES</th>
                            </tr>
                        </thead>
                        <tbody class="text-start">
                            @if (!pedidos.Any())
                            {
                                <tr>
                                    <td colspan="6" class="text-center py-4 text-muted">
                                        <em>No hay pedidos registrados o cargando datos...</em>
                                    </td>
                                </tr>
                            }
                            else if (!GetPagedOrders().Any())
                            {
                                <tr>
                                    <td colspan="6" class="text-center py-4 text-muted">No se encontraron pedidos con los filtros aplicados.</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var order in GetPagedOrders())
                                {
                                    <tr>
                                        <td class="px-2">
                                            <span class="badge-id">ID: @order.id</span>
                                        </td>
                                        <td class="text-dark fw-medium" style="font-size: 0.85rem;">
                                            @(order.cliente?.nombre ?? "Sin cliente") @(order.cliente?.apellidoCompleto ?? "")
                                        </td>
                                        <td>
                                            <div class="text-dark fw-medium" style="font-size: 0.82rem;">@(order.fechaPedido?.ToString("dd/MM/yyyy") ?? "N/A")</div>
                                            <div class="text-muted" style="font-size: 0.75rem;">@(order.fechaPedido?.ToString("hh:mm tt") ?? "--:--")</div>
                                        </td>
                                        <td>
                                            @if (updatingOrders.Contains(order.id))
                                            {
                                                <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                                            }
                                            else
                                            {
                                                <select class="badge bg-@(GetStatusColor(order.estado))" 
                                                        style="font-size: 0.82rem; border: none; cursor: pointer; outline: none; padding: 0.35em 0.65em;"
                                                        value="@order.estado" 
                                                        @onchange="@(async (e) => await ActualizarEstadoFila(order, e))">
                                                    @foreach (var estado in Enum.GetValues(typeof(EstadoPedido)))
                                                    {
                                                        <option value="@estado" class="bg-white text-dark">@estado</option>
                                                    }
                                                </select>
                                            }
                                        </td>
                                        <td>
                                            <span class="fw-bold text-dark">S/ @order.precioFinal.ToString("0.00")</span>
                                        </td>
                                        <td class="text-center text-nowrap">
                                            <button class="btn btn-outline-custom btn-sm" @onclick='() => Navigation.NavigateTo($"/admin/order-details/{order.id}")'>
                                                <i class="bi bi-eye"></i> Detalles
                                            </button>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>

                @if (TotalPages > 1)
                {
                    <div class="d-flex justify-content-center mt-3 mb-1">
                        <nav>
                            <ul class="pagination custom-pagination pagination-sm">
                                <li class="page-item @(CurrentPage == 1 ? "disabled" : "")">
                                    <button class="page-link" @onclick="GoToPreviousPage" disabled="@(CurrentPage == 1)">
                                        <i class="bi bi-chevron-left"></i>
                                    </button>
                                </li>

                                @for (int i = 1; i <= TotalPages; i++)
                                {
                                    var pageNumber = i;
                                    <li class="page-item @(CurrentPage == pageNumber ? "active" : "")">
                                        <button class="page-link" @onclick="() => ChangePage(pageNumber)">@pageNumber</button>
                                    </li>
                                }

                                <li class="page-item @(CurrentPage == TotalPages ? "disabled" : "")">
                                    <button class="page-link" @onclick="GoToNextPage" disabled="@(CurrentPage == TotalPages)">
                                        <i class="bi bi-chevron-right"></i>
                                    </button>
                                </li>
                            </ul>
                        </nav>
                    </div>
                }

            </div>
        </div>
    </Authorized>

    <NotAuthorized>
        <div class="container mt-5">
            <h2>
                Acceso denegado
            </h2>
            <p>
                No tienes permisos para acceder a esta página.
            </p>
        </div>
    </NotAuthorized>
</AuthorizeView>

@code {
    private List<Pedido> pedidos = new();
    private HashSet<int> updatingOrders = new();

    protected override async Task OnInitializedAsync()
    {
        await CargarPedidos();
    }

    private async Task CargarPedidos()
    {
        try
        {
            pedidos.Clear();

            var resultado = await PedidosRS.ListarTodosAsync();
            if (resultado != null)
            {
                pedidos = resultado;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine("Error al cargar pedidos: " + ex.Message);
        }
    }

    private string InputEstado { get; set; } = "Todos";
    private string InputCliente { get; set; } = string.Empty;
    private DateTime? InputFechaDesde { get; set; }
    private DateTime? InputFechaHasta { get; set; }

    private string AppliedEstado { get; set; } = "Todos";
    private string AppliedCliente { get; set; } = string.Empty;
    private DateTime? AppliedFechaDesde { get; set; }
    private DateTime? AppliedFechaHasta { get; set; }

    private int CurrentPage { get; set; } = 1;
    private int PageSize { get; set; } = 10;

    private IEnumerable<Pedido> FilteredOrders => pedidos.Where(o =>
        (AppliedEstado == "Todos" || o.estado.ToString() == AppliedEstado) &&
        (string.IsNullOrWhiteSpace(AppliedCliente) ||
         (o.cliente != null && (o.cliente.nombre + " " + o.cliente.apellidoCompleto).Contains(AppliedCliente, StringComparison.OrdinalIgnoreCase))) &&
        (!AppliedFechaDesde.HasValue || (o.fechaPedido.HasValue && o.fechaPedido.Value.Date >= AppliedFechaDesde.Value.Date)) &&
        (!AppliedFechaHasta.HasValue || (o.fechaPedido.HasValue && o.fechaPedido.Value.Date <= AppliedFechaHasta.Value.Date))
    );

    private int TotalPages => Math.Max(1, (int)Math.Ceiling((double)FilteredOrders.Count() / PageSize));

    private IEnumerable<Pedido> GetPagedOrders() => FilteredOrders.Skip((CurrentPage - 1) * PageSize).Take(PageSize);

    private void AplicarFiltros()
    {
        AppliedEstado = InputEstado;
        AppliedCliente = InputCliente;
        AppliedFechaDesde = InputFechaDesde;
        AppliedFechaHasta = InputFechaHasta;
        CurrentPage = 1;
    }

    private void LimpiarFiltros()
    {
        InputEstado = "Todos";
        InputCliente = string.Empty;
        InputFechaDesde = null;
        InputFechaHasta = null;
        AplicarFiltros();
    }

    private void ChangePage(int page) => CurrentPage = page;
    private void GoToPreviousPage() { if (CurrentPage > 1) CurrentPage--; }
    private void GoToNextPage() { if (CurrentPage < TotalPages) CurrentPage++; }

    private void OnPageSizeChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int newSize))
        {
            PageSize = newSize;
            CurrentPage = 1;
        }
    }

    private async Task ActualizarEstadoFila(Pedido order, ChangeEventArgs e)
    {
        if (e.Value != null && Enum.TryParse(typeof(EstadoPedido), e.Value.ToString(), out var nuevoEstadoObj))
        {
            var nuevoEstado = (EstadoPedido)nuevoEstadoObj;
            if (order.estado == nuevoEstado) return;
            
            updatingOrders.Add(order.id);
            StateHasChanged();
            
            var estadoAnterior = order.estado;
            order.estado = nuevoEstado;
            
            bool exito = await PedidosRS.ActualizarEstadoAsync(order.id, nuevoEstado);
            
            if (!exito)
            {
                order.estado = estadoAnterior; // Revertir en caso de error
            }
            
            updatingOrders.Remove(order.id);
            StateHasChanged();
        }
    }

    private string GetStatusColor(EstadoPedido status)
    {
        return status switch
        {
            EstadoPedido.PENDIENTE => "warning text-dark",
            EstadoPedido.EN_PREPARACION => "info text-dark",
            EstadoPedido.EN_CAMINO => "primary",
            EstadoPedido.ENTREGADO => "success",
            EstadoPedido.CANCELADO => "danger",
            EstadoPedido.RECHAZADO => "dark",
            _ => "secondary"
        };
    }
}

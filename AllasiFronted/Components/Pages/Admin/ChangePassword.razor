@page "/admin/change-password"
@using AllasiFrontend.Components.Shared.ui
@using Progra3_Frontend.Services
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@inject AdminsRS AdminsService
@inject AuthenticationStateProvider AuthStateProvider
@layout AdminLayout

<div class="password-page-container mt-4" style="max-width: 600px; margin: 0 auto;">

    <div class="text-center mb-4">
        <h2 class="fw-bold text-navy mb-1" style="font-size: 1.35rem;">Cambiar mi contraseña</h2>
        <p class="text-muted mb-2" style="font-size: 0.85rem;">Por tu seguridad, elige una contraseña segura que no uses en otros sitios.</p>
    </div>

    <div class="password-form-card card shadow-sm border-0 p-4" style="border-radius: 12px;">
        <EditForm Model="@passwordModel" OnValidSubmit="HandleSubmit">

            <div class="mb-3">
                <Input Password="true"
                       Label="Nueva contraseña"
                       @bind-Value="passwordModel.NewPassword"></Input>
            </div>

            <div class="mb-3">
                <IndicatorBar Color="@strengthColor" State="@strengthText" Percent="@strengthPercent" Label="Seguridad" />
            </div>

            <div class="mb-3">
                <Input Password="true"
                       Label="Repetir nueva contraseña"
                       @bind-Value="passwordModel.ConfirmPassword" />
            </div>

            <div class="requirements-box mt-2 mb-3 p-3 bg-light" style="border-radius: 8px;">
                <p class="requirements-title mb-2 fw-bold" style="font-size: 0.85rem;">
                    <i class="bi bi-info-circle text-navy me-1"></i> Tu contraseña debe contener:
                </p>
                <div class="row g-2" style="font-size: 0.85rem;">
                    <div class="col-sm-6 requirement-item">
                        <i class="bi @(hasMinLength ? "bi-check-circle-fill text-success" : "bi-x-circle text-danger") me-1"></i> Mínimo 8 caracteres
                    </div>
                    <div class="col-sm-6 requirement-item">
                        <i class="bi @(hasNumber ? "bi-check-circle-fill text-success" : "bi-x-circle text-danger") me-1"></i> Al menos un número
                    </div>
                    <div class="col-sm-6 requirement-item">
                        <i class="bi @(hasUpper ? "bi-check-circle-fill text-success" : "bi-x-circle text-danger") me-1"></i> Al menos una letra mayúscula
                    </div>
                    <div class="col-sm-6 requirement-item">
                        <i class="bi @(hasSpecial ? "bi-check-circle-fill text-success" : "bi-x-circle text-danger") me-1"></i> Al menos un carácter especial
                    </div>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(successMessage))
            {
                <div class="alert alert-success mt-3 py-2">@successMessage</div>
            }
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger mt-3 py-2">@errorMessage</div>
            }

            <div class="submit-container pt-3 mt-4" style="border-top: 1px solid rgba(170,170,170,0.3);">
                @if (isProcessing)
                {
                    <button type="button" class="btn navy-bg w-100 py-2 text-white" disabled style="border-radius: 6px; font-weight: 500; font-size: 0.85rem; opacity: 0.7; cursor: not-allowed;">
                        <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true" style="margin-right: 8px;"></span>
                        Actualizando...
                    </button>
                }
                else
                {
                    <button type="submit" class="btn navy-bg w-100 py-2 text-white" style="border-radius: 6px; font-weight: 500; font-size: 0.85rem;">Actualizar contraseña</button>
                }
            </div>

        </EditForm>
    </div>

    <p class="security-footer-text mt-4 text-center text-muted" style="font-size: 0.85rem;">
        <i class="bi bi-shield-check me-1"></i> Tu información está segura con nosotros y no será compartida con terceros.
    </p>
</div>

@code {
    private PasswordClass passwordModel = new PasswordClass();
    private string successMessage = "";
    private string errorMessage = "";
    private bool isProcessing = false;

    private bool hasMinLength => (passwordModel.NewPassword?.Length >= 8);
    private bool hasNumber => !string.IsNullOrEmpty(passwordModel.NewPassword) && passwordModel.NewPassword.Any(char.IsDigit);
    private bool hasUpper => !string.IsNullOrEmpty(passwordModel.NewPassword) && passwordModel.NewPassword.Any(char.IsUpper);
    private bool hasSpecial => !string.IsNullOrEmpty(passwordModel.NewPassword) && passwordModel.NewPassword.Any(c => !char.IsLetterOrDigit(c));

    private int PasswordScore
    {
        get
        {
            if (string.IsNullOrEmpty(passwordModel.NewPassword)) return 0;
            int score = 0;
            if (hasMinLength) score++;
            if (hasNumber) score++;
            if (hasUpper) score++;
            if (hasSpecial) score++;
            return score;
        }
    }

    private string strengthText => PasswordScore switch
    {
        4 => "Fuerte",
        3 => "Media",
        2 => "Media",
        _ => "Débil"
    };

    private string strengthColor => PasswordScore switch
    {
        4 => "#198754", 
        3 => "#ffc107", 
        2 => "#ffc107", 
        _ => "#dc3545"  
    };

    private int strengthPercent => PasswordScore switch
    {
        4 => 100,
        3 => 75,
        2 => 50,
        1 => 25,
        _ => 15
    };

    private async Task HandleSubmit()
    {
        if (isProcessing) return;
        isProcessing = true;
        successMessage = "";
        errorMessage = "";

        try
        {

        if (passwordModel.NewPassword != passwordModel.ConfirmPassword)
        {
            errorMessage = "Las contraseñas no coinciden.";
            return;
        }

        if (strengthPercent < 100)
        {
            errorMessage = "La nueva contraseña no cumple con todos los requisitos de seguridad.";
            return;
        }

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        
        if (user.Identity != null && user.Identity.IsAuthenticated)
        {
            var userIdClaim = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            if (int.TryParse(userIdClaim, out int userId))
            {
                bool success = await AdminsService.CambiarPasswordAsync(userId, passwordModel.NewPassword);
                if (success)
                {
                    successMessage = "Contraseña cambiada exitosamente.";
                    passwordModel = new PasswordClass(); // Limpiar el formulario
                }
                else
                {
                    errorMessage = "Error al cambiar la contraseña. Verifica tu contraseña actual e intenta nuevamente.";
                }
            }
            else
            {
                errorMessage = "No se pudo identificar el usuario actual.";
            }
        }
        else
        {
            errorMessage = "No has iniciado sesión.";
        }
        }
        finally
        {
            isProcessing = false;
        }
    }

    public class PasswordClass
    {
        public string CurrentPassword { get; set; } = string.Empty;
        public string NewPassword { get; set; } = string.Empty;
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}

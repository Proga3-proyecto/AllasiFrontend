@page "/admin/report-product"
@layout AdminLayout

@inject NavigationManager Navigation

@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.JSInterop
@using Progra3_Frontend.Model
@using Progra3_Frontend.Services
@using QuestPDF.Fluent
@using QuestPDF.Helpers
@using QuestPDF.Infrastructure

@inject PedidosRS pedidosRS
@inject IJSRuntime JS

<AuthorizeView Roles="ADMIN" Context="authContext">
    <Authorized>
        <div class="product-report-page container-fluid mt-3 mb-4">

    <div class="report-header">

        <div class="d-flex align-items-center gap-2">

            <button type="button"
                    class="btn navy-bg"
                    @onclick='() => Navigation.NavigateTo("/admin/report-list")'>

                <i class="bi bi-arrow-left me-1"></i>
                Regresar
            </button>

            <button type="button"
                    class="btn navy-bg"
                    @onclick="ExportarPdf">

                <i class="bi bi-download me-1"></i>
                Exportar PDF
            </button>

        </div>


        <div>
            <h2 class="report-title text-navy">
                Reporte por Producto
            </h2>

            <p class="report-subtitle">
                Consulta el precio y la cantidad vendida de cada producto.
            </p>
        </div>


    </div>

    <div class="filter-panel"
         style="grid-template-columns: 1fr 1fr;">

        <div class="filter-group">

            <label>Ordenar por</label>

            <div class="input-container">
                <i class="bi bi-filter"></i>

                <select @bind="CriterioOrden">
                    <option value="cantidad">
                        Cantidad vendida
                    </option>

                    <option value="precio">
                        Precio
                    </option>
                </select>
            </div>

        </div>

        <div class="filter-group">

            <label>Tipo de orden</label>

            <div class="input-container">
                <i class="bi bi-sort-down"></i>

                <select @bind="TipoOrden">
                    <option value="descendente">
                        Mayor a menor
                    </option>

                    <option value="ascendente">
                        Menor a mayor
                    </option>
                </select>
            </div>

        </div>

    </div>

    <div class="table-container">

        <div class="table-responsive">

            <table class="table custom-table table-borderless align-middle w-100">

                <thead>
                    <tr>
                        <th class="text-start">
                            PRODUCTO
                        </th>

                        <th class="text-center">
                            PRECIO
                        </th>

                        <th class="text-center">
                            CANTIDAD VENDIDA
                        </th>
                    </tr>
                </thead>

                <tbody>
                    @if (isLoading)
                    {
                        <tr>
                            <td colspan="3" class="text-center py-5 text-muted">
                                <div class="d-flex flex-column align-items-center justify-content-center">
                                    <span class="spinner-border text-navy mb-2" role="status" aria-hidden="true" style="width: 2rem; height: 2rem;"></span>
                                    <span>Cargando reporte...</span>
                                </div>
                            </td>
                        </tr>
                    }
                    else if (!ProductosOrdenados.Any())
                    {
                        <tr>
                            <td colspan="3" class="text-center py-4 text-muted">
                                <em>No se encontraron datos.</em>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var producto in ProductosOrdenados)
                        {
                            <tr>

                                <td class="text-start">

                                    <div class="d-flex align-items-center gap-2">

                                        <div class="summary-icon"
                                             style="width: 36px;
                                            height: 36px;">

                                            <svg xmlns="http://www.w3.org/2000/svg"
                                                 width="18"
                                                 height="18"
                                                 fill="currentColor"
                                                 viewBox="0 0 16 16">

                                                <path d="M1 2h14L9 8.8V14h3v1H4v-1h3V8.8L1 2zm2.2 1 4.8 5.4L12.8 3H3.2z" />
                                            </svg>

                                        </div>

                                        <span class="fw-bold text-navy">
                                            @producto.Nombre
                                        </span>

                                    </div>

                                </td>

                                <td class="text-center text-nowrap">

                                    <span class="fw-bold text-dark">
                                        S/ @producto.Precio.ToString("0.00")
                                    </span>

                                </td>

                                <td class="text-center text-nowrap">

                                    <span class="fw-bold text-navy">
                                        @producto.CantidadVendida
                                    </span>

                                </td>

                            </tr>
                        }
                    }
                </tbody>

            </table>

        </div>

    </div>

</div>


    </Authorized>
    <NotAuthorized>
        <div class="container mt-5">
            <h2>Acceso denegado</h2>
            <p>No tienes permisos para acceder a esta página.</p>
        </div>
    </NotAuthorized>
</AuthorizeView>

@code {
    private string CriterioOrden { get; set; } = "cantidad";

    private string TipoOrden { get; set; } = "descendente";

    private List<ProductoReporte> Productos { get; set; } = new();
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
        List<Pedido> pedidos = await pedidosRS.ListarTodosAsync();

        Productos = pedidos
            .SelectMany(pedido => pedido.detallesProductos)
            .Where(detalle => detalle.productoSnapshot != null)
            .GroupBy(detalle => new
            {
                detalle.productoSnapshot.nombre,
                detalle.productoSnapshot.precioFinalVenta
            })
            .Select(grupo => new ProductoReporte
            {
                Nombre = grupo.Key.nombre,

                Precio = grupo.Key.precioFinalVenta,

                CantidadVendida = grupo.Sum(
                    detalle => detalle.cantidad
                )
            }).ToList();

        isLoading = false;
    }


    private IEnumerable<ProductoReporte> ProductosOrdenados
    {
        get
        {
            if (Productos == null) return [];

            if (CriterioOrden == "precio")
            {
                return TipoOrden == "ascendente"
                    ? Productos.OrderBy(producto => producto.Precio)
                    : Productos.OrderByDescending(producto => producto.Precio);
            }

            return TipoOrden == "ascendente"
                ? Productos.OrderBy(producto => producto.CantidadVendida)
                : Productos.OrderByDescending(producto => producto.CantidadVendida);
        }
    }

    private class ProductoReporte
    {
        public string Nombre { get; set; } = string.Empty;

        public double Precio { get; set; }

        public int CantidadVendida { get; set; }
    }

	public async Task ExportarPdf()
	{
	    QuestPDF.Settings.License = LicenseType.Community;
	
	    List<ProductoReporte> productosExportar =
	        ProductosOrdenados.ToList();
	
	    int totalUnidades = productosExportar.Sum(
	        producto => producto.CantidadVendida
	    );
	
	    List<ProductoReporte> productosGrafica = productosExportar
	        .OrderByDescending(producto => producto.CantidadVendida)
	        .Take(10)
	        .ToList();
	
	    int cantidadMaxima = productosGrafica.Count > 0
	        ? productosGrafica.Max(
	            producto => producto.CantidadVendida
	        )
	        : 1;
	
	    string fechaGeneracion =
	        DateTime.Now.ToString("dd/MM/yyyy HH:mm");
	
	    const string azulPrincipal = "#101C45";
	    const string azulClaro = "#EEF2FF";
	    const string textoPrincipal = "#1E293B";
	    const string textoSecundario = "#64748B";
	    const string fondoAlterno = "#F8FAFC";
	    const string bordeGris = "#E2E8F0";
	    const string fondoBarra = "#DDE3EC";
	
	    byte[] pdf = Document.Create(document =>
	    {
	        document.Page(page =>
	        {
	            page.Size(PageSizes.A4);
	            page.Margin(30);
	            page.PageColor(Colors.White);
	
	            page.DefaultTextStyle(style => style
	                .FontSize(9)
	                .FontColor(textoPrincipal)
	            );
	
	            /* =========================================
	               ENCABEZADO
	               ========================================= */
	
	            page.Header().Column(header =>
	            {
	                header.Item().Row(row =>
	                {
	                    row.RelativeItem().Column(title =>
	                    {
	                        title.Item()
	                            .Text("Reporte por Producto")
	                            .FontSize(21)
	                            .FontColor(azulPrincipal)
	                            .Bold();
	
	                        title.Item()
	                            .PaddingTop(3)
	                            .Text(
	                                "Resumen de productos y unidades vendidas"
	                            )
	                            .FontSize(9)
	                            .FontColor(textoSecundario);
	                    });
	
	                    row.ConstantItem(170).Column(info =>
	                    {
	                        info.Item()
	                            .AlignRight()
	                            .Text("Fecha de generación")
	                            .FontSize(8)
	                            .FontColor(textoSecundario);
	
	                        info.Item()
	                            .PaddingTop(3)
	                            .AlignRight()
	                            .Text(fechaGeneracion)
	                            .FontSize(9)
	                            .SemiBold();
	                    });
	                });
	
	                header.Item()
	                    .PaddingTop(12)
	                    .LineHorizontal(2)
	                    .LineColor(azulPrincipal);
	            });
	
	            /* =========================================
	               CONTENIDO
	               ========================================= */
	
	            page.Content()
	                .PaddingTop(18)
	                .PaddingBottom(15)
	                .Column(column =>
	                {
	                    column.Spacing(14);
	
	                    /* Tarjetas de resumen */
	
	                    column.Item().Row(row =>
	                    {
	                        row.RelativeItem()
	                            .PaddingRight(6)
	                            .Background(azulClaro)
	                            .Border(1)
	                            .BorderColor(bordeGris)
	                            .Padding(14)
	                            .Column(card =>
	                            {
	                                card.Item()
	                                    .Text("TOTAL DE PRODUCTOS")
	                                    .FontSize(8)
	                                    .FontColor(textoSecundario)
	                                    .SemiBold();
	
	                                card.Item()
	                                    .PaddingTop(5)
	                                    .Text(
	                                        productosExportar.Count.ToString()
	                                    )
	                                    .FontSize(18)
	                                    .FontColor(azulPrincipal)
	                                    .Bold();
	                            });
	
	                        row.RelativeItem()
	                            .PaddingLeft(6)
	                            .Background(azulClaro)
	                            .Border(1)
	                            .BorderColor(bordeGris)
	                            .Padding(14)
	                            .Column(card =>
	                            {
	                                card.Item()
	                                    .Text("TOTAL DE UNIDADES VENDIDAS")
	                                    .FontSize(8)
	                                    .FontColor(textoSecundario)
	                                    .SemiBold();
	
	                                card.Item()
	                                    .PaddingTop(5)
	                                    .Text(totalUnidades.ToString())
	                                    .FontSize(18)
	                                    .FontColor(azulPrincipal)
	                                    .Bold();
	                            });
	                    });
	
	                    /* Título de la tabla */
	
	                    column.Item()
	                        .PaddingTop(5)
	                        .Column(title =>
	                        {
	                            title.Item()
	                                .Text("Detalle de productos")
	                                .FontSize(14)
	                                .FontColor(azulPrincipal)
	                                .Bold();
	
	                            title.Item()
	                                .PaddingTop(2)
	                                .Text(
	                                    "Listado de productos, precios y unidades vendidas"
	                                )
	                                .FontSize(8)
	                                .FontColor(textoSecundario);
	                        });
	
	                    /* Tabla */
	
	                    column.Item()
	                        .Border(1)
	                        .BorderColor(bordeGris)
	                        .Table(table =>
	                        {
	                            table.ColumnsDefinition(columns =>
	                            {
	                                columns.RelativeColumn();
	                                columns.ConstantColumn(105);
	                                columns.ConstantColumn(125);
	                            });
	
	                            table.Header(header =>
	                            {
	                                header.Cell()
	                                    .Background(azulPrincipal)
	                                    .PaddingVertical(8)
	                                    .PaddingHorizontal(7)
	                                    .Text("PRODUCTO")
	                                    .FontSize(8)
	                                    .FontColor(Colors.White)
	                                    .Bold();
	
	                                header.Cell()
	                                    .Background(azulPrincipal)
	                                    .PaddingVertical(8)
	                                    .PaddingHorizontal(7)
	                                    .AlignRight()
	                                    .Text("PRECIO")
	                                    .FontSize(8)
	                                    .FontColor(Colors.White)
	                                    .Bold();
	
	                                header.Cell()
	                                    .Background(azulPrincipal)
	                                    .PaddingVertical(8)
	                                    .PaddingHorizontal(7)
	                                    .AlignCenter()
	                                    .Text("CANTIDAD VENDIDA")
	                                    .FontSize(8)
	                                    .FontColor(Colors.White)
	                                    .Bold();
	                            });
	
	                            for (
	                                int indice = 0;
	                                indice < productosExportar.Count;
	                                indice++
	                            )
	                            {
	                                ProductoReporte producto =
	                                    productosExportar[indice];
	
	                                string fondoFila = indice % 2 == 0
	                                    ? Colors.White
	                                    : fondoAlterno;
	
	                                table.Cell()
	                                    .Background(fondoFila)
	                                    .BorderBottom(1)
	                                    .BorderColor(bordeGris)
	                                    .PaddingVertical(7)
	                                    .PaddingHorizontal(7)
	                                    .Text(producto.Nombre ?? "");
	
	                                table.Cell()
	                                    .Background(fondoFila)
	                                    .BorderBottom(1)
	                                    .BorderColor(bordeGris)
	                                    .PaddingVertical(7)
	                                    .PaddingHorizontal(7)
	                                    .AlignRight()
	                                    .Text($"S/ {producto.Precio:N2}");
	
	                                table.Cell()
	                                    .Background(fondoFila)
	                                    .BorderBottom(1)
	                                    .BorderColor(bordeGris)
	                                    .PaddingVertical(7)
	                                    .PaddingHorizontal(7)
	                                    .AlignCenter()
	                                    .Text(
	                                        producto.CantidadVendida.ToString()
	                                    )
	                                    .SemiBold();
	                            }
	
	                            /* Fila de totales */
	
	                            table.Cell()
	                                .ColumnSpan(2)
	                                .Background(azulClaro)
	                                .PaddingVertical(9)
	                                .PaddingHorizontal(7)
	                                .AlignRight()
	                                .Text("TOTAL DE UNIDADES")
	                                .FontColor(azulPrincipal)
	                                .Bold();
	
	                            table.Cell()
	                                .Background(azulClaro)
	                                .PaddingVertical(9)
	                                .PaddingHorizontal(7)
	                                .AlignCenter()
	                                .Text(totalUnidades.ToString())
	                                .FontColor(azulPrincipal)
	                                .Bold();
	                        });
	
	                    /* Gráfica */
	
	                    if (productosGrafica.Count > 0)
	                    {
	                        column.Item()
	                            .PaddingTop(10)
	                            .Column(title =>
	                            {
	                                title.Item()
	                                    .Text(
	                                        "Productos con más unidades vendidas"
	                                    )
	                                    .FontSize(14)
	                                    .FontColor(azulPrincipal)
	                                    .Bold();
	
	                                title.Item()
	                                    .PaddingTop(2)
	                                    .Text(
	                                        "Los 10 productos con mayor cantidad de unidades vendidas"
	                                    )
	                                    .FontSize(8)
	                                    .FontColor(textoSecundario);
	                            });
	
	                        column.Item()
	                            .Background(fondoAlterno)
	                            .Border(1)
	                            .BorderColor(bordeGris)
	                            .Padding(15)
	                            .Column(chart =>
	                            {
	                                chart.Spacing(10);
	
	                                foreach (
	                                    ProductoReporte producto
	                                    in productosGrafica
	                                )
	                                {
	                                    float porcentaje =
	                                        cantidadMaxima > 0
	                                            ? (float)
	                                              producto.CantidadVendida /
	                                              cantidadMaxima *
	                                              100
	                                            : 0;
	
	                                    porcentaje = Math.Clamp(
	                                        porcentaje,
	                                        1f,
	                                        100f
	                                    );
	
	                                    float restante = Math.Max(
	                                        100f - porcentaje,
	                                        0f
	                                    );
	
	                                    chart.Item().Column(bar =>
	                                    {
	                                        bar.Item().Row(row =>
	                                        {
	                                            row.RelativeItem()
	                                                .Text(
	                                                    producto.Nombre ?? ""
	                                                )
	                                                .FontSize(8)
	                                                .SemiBold();
	
	                                            row.ConstantItem(110)
	                                                .AlignRight()
	                                                .Text(
	                                                    $"{producto.CantidadVendida} unidades"
	                                                )
	                                                .FontSize(8)
	                                                .FontColor(azulPrincipal)
	                                                .Bold();
	                                        });
	
	                                        bar.Item()
	                                            .PaddingTop(4)
	                                            .Height(13)
	                                            .Row(row =>
	                                            {
	                                                row.RelativeItem(
	                                                        porcentaje
	                                                    )
	                                                    .Background(
	                                                        azulPrincipal
	                                                    );
	
	                                                if (restante > 0)
	                                                {
	                                                    row.RelativeItem(
	                                                            restante
	                                                        )
	                                                        .Background(
	                                                            fondoBarra
	                                                        );
	                                                }
	                                            });
	                                    });
	                                }
	                            });
	                    }
	                    else
	                    {
	                        column.Item()
	                            .PaddingTop(10)
	                            .Background(fondoAlterno)
	                            .Border(1)
	                            .BorderColor(bordeGris)
	                            .Padding(15)
	                            .AlignCenter()
	                            .Text(
	                                "No existen datos para generar la gráfica."
	                            )
	                            .FontColor(textoSecundario);
	                    }
	                });
	
	            /* =========================================
	               PIE DE PÁGINA
	               ========================================= */
	
	            page.Footer().Column(footer =>
	            {
	                footer.Item()
	                    .LineHorizontal(1)
	                    .LineColor(bordeGris);
	
	                footer.Item()
	                    .PaddingTop(7)
	                    .Row(row =>
	                    {
	                        row.RelativeItem()
	                            .Text("Reporte por Producto")
	                            .FontSize(8)
	                            .FontColor(textoSecundario);
	
	                        row.RelativeItem()
	                            .AlignRight()
	                            .Text(text =>
	                            {
	                                text.DefaultTextStyle(style => style
	                                    .FontSize(8)
	                                    .FontColor(textoSecundario)
	                                );
	
	                                text.Span("Página ");
	                                text.CurrentPageNumber();
	                                text.Span(" de ");
	                                text.TotalPages();
	                            });
	                    });
	            });
	        });
	    }).GeneratePdf();
	
	    await JS.InvokeVoidAsync(
	        "descargarArchivo",
	        $"ReporteProductos_{DateTime.Now:yyyyMMdd_HHmm}.pdf",
	        "application/pdf",
	        Convert.ToBase64String(pdf)
	    );
	}
}

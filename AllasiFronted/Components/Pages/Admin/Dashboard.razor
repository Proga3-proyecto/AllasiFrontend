@page "/admin/dashboard"
@layout AdminLayout

@inject NavigationManager Navigation

@using Microsoft.AspNetCore.Components.Authorization

<AuthorizeView Roles="ADMIN,MASTER" Context="authContext">

    <Authorized>

        <div class="dashboard-list-page container-fluid mt-3 mb-4">

            <div class="text-center mb-4">

                <h2 class="fw-bold text-navy main-title">
                    Dashboard
                </h2>

                <p class="text-muted mb-0">
                    Selecciona el dashboard que deseas consultar.
                </p>

            </div>

            <div class="dashboard-grid">

                <button type="button"
                        class="dashboard-card"
                        @onclick='() => Navigation.NavigateTo("/admin/dashboard-sales")'>

                    <div class="dashboard-image">

                        <svg viewBox="0 0 240 170"
                             role="img"
                             aria-label="Dashboard de ventas">

                            <rect x="25"
                                  y="24"
                                  width="190"
                                  height="122"
                                  rx="14"
                                  class="svg-panel" />

                            <path d="M47 119 H193"
                                  class="svg-axis" />

                            <rect x="56"
                                  y="88"
                                  width="20"
                                  height="31"
                                  rx="4"
                                  class="svg-bar" />

                            <rect x="91"
                                  y="70"
                                  width="20"
                                  height="49"
                                  rx="4"
                                  class="svg-bar" />

                            <rect x="126"
                                  y="51"
                                  width="20"
                                  height="68"
                                  rx="4"
                                  class="svg-bar" />

                            <rect x="161"
                                  y="36"
                                  width="20"
                                  height="83"
                                  rx="4"
                                  class="svg-bar" />

                            <path d="M56 78
                            L101 59
                            L136 44
                            L171 29"
                                  class="svg-line" />

                            <circle cx="56"
                                    cy="78"
                                    r="4"
                                    class="svg-point" />

                            <circle cx="101"
                                    cy="59"
                                    r="4"
                                    class="svg-point" />

                            <circle cx="136"
                                    cy="44"
                                    r="4"
                                    class="svg-point" />

                            <circle cx="171"
                                    cy="29"
                                    r="4"
                                    class="svg-point" />

                        </svg>

                    </div>

                    <div class="dashboard-card-content">

                        <div class="dashboard-icon">
                            <i class="bi bi-graph-up-arrow"></i>
                        </div>

                        <div class="dashboard-card-text">

                            <h3>Dashboard de Ventas</h3>

                            <p>
                                Consulta los ingresos totales generados
                                en cada mes durante el año.
                            </p>

                        </div>

                        <div class="dashboard-arrow">
                            <span>Ingresar</span>
                            <i class="bi bi-arrow-right"></i>
                        </div>

                    </div>

                </button>

            </div>

        </div>

    </Authorized>

    <NotAuthorized>

        <div class="container mt-5">

            <h2>Acceso denegado</h2>

            <p>
                No tienes permisos para acceder a esta página.
            </p>

        </div>

    </NotAuthorized>

</AuthorizeView>

@page "/admin/recipe-list"
@layout AdminLayout

@using Progra3_Frontend.Model
@using Progra3_Frontend.Services

@inject RecetasRS RecetasRS
@inject NavigationManager Navigation

@using Microsoft.AspNetCore.Components.Authorization

<AuthorizeView Roles="ADMIN" Context="authContext">
    <Authorized>
        <div class="recipe-list-page container-fluid mt-3" style="max-width: 1400px;">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="fw-bold text-navy mb-0 main-title">
            Gestión de Recetas
        </h2>

        <button class="btn navy-bg d-flex align-items-center gap-2"
                @onclick="@(() => Navigation.NavigateTo("/admin/add-recipe"))">
            <i class="bi bi-plus-lg" style="font-size: 0.8rem;"></i>
            Añadir Nueva Receta
        </button>
    </div>

    <div class="mb-3">
        <div class="input-container"
             style="max-width: 400px; background-color: white;">
            <i class="bi bi-search"></i>

            <input type="text"
                   placeholder="Buscar por nombre o descripción..."
                   @bind="TextoBusqueda"
                   @bind:event="oninput" />
        </div>
    </div>

    <div class="table-container">
        <div class="table-responsive">

            <table class="table custom-table table-borderless align-middle w-100">

                <thead class="text-start">
                    <tr>
                        <th scope="col"
                            style="width: 25%;"
                            class="text-start px-2">
                            RECETA
                        </th>

                        <th scope="col"
                            style="width: 30%;"
                            class="text-start">
                            DESCRIPCIÓN
                        </th>

                        <th scope="col" class="text-center">
                            PRECIO
                        </th>

                        <th scope="col" class="text-center">
                            PRECIO FINAL
                        </th>

                        <th scope="col" class="text-center">
                            DESCUENTO
                        </th>

                        <th scope="col" class="text-center">
                            ACCIONES
                        </th>
                    </tr>
                </thead>

                <tbody class="text-start">

                    @if (isLoading)
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">
                                <div class="d-flex flex-column align-items-center justify-content-center">
                                    <span class="spinner-border text-navy mb-2" role="status" aria-hidden="true" style="width: 2rem; height: 2rem;"></span>
                                    <span>Cargando recetas...</span>
                                </div>
                            </td>
                        </tr>
                    }
                    else if (!RecetasFiltradas.Any())
                    {
                        <tr>
                            <td colspan="6"
                                class="text-center py-4 text-muted">
                                <em>
                                    No hay recetas registradas.
                                </em>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var receta in GetPagedRecipes())
                        {
                            <tr>

                                <td class="px-2">
                                    <div class="d-flex align-items-center">

                                        <div class="recipe-img-container flex-shrink-0">
                                            @{
                                                var imageUrl = receta.imagenes?.FirstOrDefault(i => i.principal)?.url ??
                                                               receta.imagenes?.FirstOrDefault()?.url;
                                            }
                                            @if (!string.IsNullOrEmpty(imageUrl))
                                            {
                                                <img src="@imageUrl" alt="@receta.nombre" class="recipe-img" />
                                            }
                                            else
                                            {
                                                <i class="bi bi-journal-richtext"></i>
                                            }
                                        </div>

                                        <span class="fw-bold text-navy recipe-name">
                                            @receta.nombre
                                        </span>

                                    </div>
                                </td>

                                <td class="text-muted">
                                    @receta.descripcion
                                </td>

                                <td class="text-center text-nowrap">
                                    <span class="fw-bold text-dark">
                                        S/ @receta.precio.ToString("0.00")
                                    </span>
                                </td>

                                <td class="text-center text-nowrap">
                                    <span class="fw-bold text-navy">
                                        S/ @receta.precioFinal.ToString("0.00")
                                    </span>
                                </td>

                                <td class="text-center text-nowrap">
                                    @if (receta.descuento > 0)
                                    {
                                        <span class="badge bg-success">
                                            @receta.descuento.ToString("0.##")%
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">
                                            Sin descuento
                                        </span>
                                    }
                                </td>

                                <td class="text-center text-nowrap">

                                    <button class="btn btn-outline-custom btn-sm me-2" disabled="@(processingItemId != null)"
                                            @onclick="() => EditarReceta(receta.id)">
                                        @if (processingItemId == receta.id && processingAction == "Modificar")
                                        {
                                            <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                                        }
                                        else
                                        {
                                            <span>Modificar</span>
                                        }
                                    </button>

                                    <button class="btn btn-danger btn-sm" disabled="@(processingItemId != null)"
                                            @onclick="() => EliminarReceta(receta.id)">
                                        @if (processingItemId == receta.id && processingAction == "Eliminar")
                                        {
                                            <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                                        }
                                        else
                                        {
                                            <span>Eliminar</span>
                                        }
                                    </button>

                                </td>

                            </tr>
                        }
                    }

                </tbody>

            </table>

        </div>

        @if (TotalPages > 1)
        {
            <div class="d-flex justify-content-center mt-3 mb-1">
                <nav>
                    <ul class="pagination custom-pagination pagination-sm">

                        <li class="page-item @(CurrentPage == 1 ? "disabled" : "")">
                            <button class="page-link"
                                    @onclick="GoToPreviousPage"
                                    disabled="@(CurrentPage == 1)">
                                <i class="bi bi-chevron-left"></i>
                            </button>
                        </li>

                        @for (int i = 1; i <= TotalPages; i++)
                        {
                            int pageNumber = i;

                            <li class="page-item @(CurrentPage == pageNumber ? "active" : "")">
                                <button class="page-link"
                                        @onclick="() => ChangePage(pageNumber)">
                                    @pageNumber
                                </button>
                            </li>
                        }

                        <li class="page-item @(CurrentPage == TotalPages ? "disabled" : "")">
                            <button class="page-link"
                                    @onclick="GoToNextPage"
                                    disabled="@(CurrentPage == TotalPages)">
                                <i class="bi bi-chevron-right"></i>
                            </button>
                        </li>

                    </ul>
                </nav>
            </div>
        }

    </div>

</div>

    </Authorized>
    <NotAuthorized>
        <div class="container mt-5">
            <h2>Acceso denegado</h2>
            <p>No tienes permisos para acceder a esta página.</p>
        </div>
    </NotAuthorized>
</AuthorizeView>

@code {
    private List<Receta> recetas = new();
    private string TextoBusqueda { get; set; } = string.Empty;
    private bool isLoading = true;
    private int? processingItemId = null;
    private string processingAction = "";

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
        await CargarRecetas();
        isLoading = false;
    }

    private async Task CargarRecetas()
    {
        try
        {
            recetas.Clear();

            var resultado = await RecetasRS.ListarTodosAsync();

            if (resultado != null)
            {
                recetas = resultado;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine(
                $"Error al cargar recetas: {ex.Message}"
            );
        }
    }

    private IEnumerable<Receta> RecetasFiltradas =>
        string.IsNullOrWhiteSpace(TextoBusqueda)
            ? recetas
            : recetas.Where(receta =>
                (receta.nombre?.Contains(
                    TextoBusqueda,
                    StringComparison.OrdinalIgnoreCase
                ) ?? false)
                ||
                (receta.descripcion?.Contains(
                    TextoBusqueda,
                    StringComparison.OrdinalIgnoreCase
                ) ?? false)
            );

    private async Task EditarReceta(int idReceta)
    {
        processingItemId = idReceta;
        processingAction = "Modificar";
        StateHasChanged();
        await Task.Delay(150);
        Navigation.NavigateTo(
            $"/admin/update-recipe/{idReceta}"
        );
        processingItemId = null;
        processingAction = "";
    }

    private async Task EliminarReceta(int idReceta)
    {
        processingItemId = idReceta;
        processingAction = "Eliminar";
        try
        {
            bool exito =
                await RecetasRS.EliminarAsync(idReceta);

            if (exito)
            {
                await CargarRecetas();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine(
                $"Error al eliminar la receta: {ex.Message}"
            );
        }
        finally
        {
            processingItemId = null;
            processingAction = "";
        }
    }

    private int CurrentPage { get; set; } = 1;
    private int PageSize { get; set; } = 10;

    private int TotalPages =>
        Math.Max(
            1,
            (int)Math.Ceiling(
                (double)RecetasFiltradas.Count() / PageSize
            )
        );

    private IEnumerable<Receta> GetPagedRecipes()
    {
        return RecetasFiltradas
            .Skip((CurrentPage - 1) * PageSize)
            .Take(PageSize);
    }

    private void ChangePage(int page)
    {
        CurrentPage = page;
    }

    private void GoToPreviousPage()
    {
        if (CurrentPage > 1)
        {
            CurrentPage--;
        }
    }

    private void GoToNextPage()
    {
        if (CurrentPage < TotalPages)
        {
            CurrentPage++;
        }
    }
}

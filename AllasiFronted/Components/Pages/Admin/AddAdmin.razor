@page "/admin/add-admin"
@using Microsoft.AspNetCore.Components.Authorization
@layout AdminLayout

@using Progra3_Frontend.Model
@using Progra3_Frontend.Services
@using System.ComponentModel.DataAnnotations
@using AllasiFrontend.Components.Shared.ui

@inject AdminsRS AdminsRS
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthenticationStateProvider

<AuthorizeView Roles="MASTER" Context="authContext">
    <Authorized>
        <div class="container-fluid mt-3" style="max-width: 1000px;">

            <div class="d-flex align-items-center gap-2 mb-3">
                <button class="btn p-0 text-navy" @onclick="Cancelar" style="font-size: 1.2rem;">
                    <i class="bi bi-arrow-left"></i>
                </button>
                <h2 class="fw-bold text-navy mb-0" style="font-size: 1.35rem;">Agregar nuevo usuario</h2>
            </div>

            <div class="table-container shadow-sm p-4" style="background-color: white; border-radius: 8px;">

                <EditForm Model="@usuarioForm" OnValidSubmit="GuardarUsuario">
                    <DataAnnotationsValidator />

                    <div class="row g-4">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold text-dark" style="font-size: 0.85rem;">DNI</label>
                            <InputText @bind-Value="usuarioForm.Dni" class="form-control custom-input" placeholder="Ej. 12345678" maxlength="8" />
                            <ValidationMessage For="@(() => usuarioForm.Dni)" class="text-danger small mt-1" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-semibold text-dark" style="font-size: 0.85rem;">NOMBRE</label>
                            <InputText @bind-Value="usuarioForm.Nombre" class="form-control custom-input" placeholder="Ej. Juan Carlos" />
                            <ValidationMessage For="@(() => usuarioForm.Nombre)" class="text-danger small mt-1" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-semibold text-dark" style="font-size: 0.85rem;">APELLIDO COMPLETO</label>
                            <InputText @bind-Value="usuarioForm.ApellidoCompleto" class="form-control custom-input" placeholder="Ej. Pérez Gómez" />
                            <ValidationMessage For="@(() => usuarioForm.ApellidoCompleto)" class="text-danger small mt-1" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-semibold text-dark" style="font-size: 0.85rem;">CORREO ELECTRÓNICO</label>
                            <InputText @bind-Value="usuarioForm.Correo" type="email" class="form-control custom-input" placeholder="ejemplo@licoreria.com" />
                            <ValidationMessage For="@(() => usuarioForm.Correo)" class="text-danger small mt-1" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-semibold text-dark" style="font-size: 0.85rem;">CONTRASEÑA</label>
                            <input type="password" class="form-control custom-input" placeholder="••••••••" @bind="usuarioForm.Contrasena" @bind:event="oninput" />
                            <ValidationMessage For="@(() => usuarioForm.Contrasena)" class="text-danger small mt-1" />
                            
                            <div class="mt-2">
                                <IndicatorBar Color="@strengthColor" State="@strengthText" Percent="@strengthPercent" Label="Seguridad" />
                            </div>
                            
                            <div class="requirements-box mt-2 p-2 bg-light" style="border-radius: 8px;">
                                <div class="row g-1" style="font-size: 0.75rem;">
                                    <div class="col-sm-6">
                                        <i class="bi @(hasMinLength ? "bi-check-circle-fill text-success" : "bi-x-circle text-danger") me-1"></i> Mínimo 8 caracteres
                                    </div>
                                    <div class="col-sm-6">
                                        <i class="bi @(hasNumber ? "bi-check-circle-fill text-success" : "bi-x-circle text-danger") me-1"></i> Al menos un número
                                    </div>
                                    <div class="col-sm-6">
                                        <i class="bi @(hasUpper ? "bi-check-circle-fill text-success" : "bi-x-circle text-danger") me-1"></i> Al menos una mayúscula
                                    </div>
                                    <div class="col-sm-6">
                                        <i class="bi @(hasSpecial ? "bi-check-circle-fill text-success" : "bi-x-circle text-danger") me-1"></i> Al menos un carácter especial
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-semibold text-dark" style="font-size: 0.85rem;">ROL DE USUARIO</label>
                            <InputText @bind-Value="usuarioForm.Rol" class="form-control custom-input bg-light text-muted" disabled />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-semibold text-dark" style="font-size: 0.85rem;">ESTADO INICIAL</label>
                            <InputSelect @bind-Value="usuarioForm.Estado" class="form-select custom-input">
                                <option value="Activo">Activo</option>
                                <option value="Inactivo">Inactivo</option>
                            </InputSelect>
                            <ValidationMessage For="@(() => usuarioForm.Estado)" class="text-danger small mt-1" />
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-5 pt-3 border-top">
                        <button type="button" class="btn btn-filter-inactive fw-medium" style="border-radius: 6px; padding: 6px 18px; font-size: 0.85rem;" @onclick="Cancelar">
                            Cancelar
                        </button>
                        @if (isProcessing)
                        {
                            <button type="button" class="btn navy-bg d-flex align-items-center gap-2 fw-medium" disabled style="border-radius: 6px; padding: 6px 18px; font-size: 0.85rem; opacity: 0.7; cursor: not-allowed;">
                                <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Guardando...
                            </button>
                        }
                        else
                        {
                            <button type="submit" class="btn navy-bg d-flex align-items-center gap-2 fw-medium" style="border-radius: 6px; padding: 6px 18px; font-size: 0.85rem;">
                                <i class="bi bi-save"></i> Guardar usuario
                            </button>
                        }
                    </div>
                </EditForm>

            </div>
        </div>
    </Authorized>

    <NotAuthorized>
        <div class="container mt-5">
            <h2>Acceso denegado</h2>
            <p>No tienes permisos para acceder a esta página.</p>
        </div>
    </NotAuthorized>
</AuthorizeView>

@code {
    public class UsuarioFormModel
    {
        [Required(ErrorMessage = "El DNI es obligatorio.")]
        [RegularExpression(@"^\d{8}$", ErrorMessage = "El DNI debe tener exactamente 8 dígitos numéricos.")]
        public string Dni { get; set; } = string.Empty;

        [Required(ErrorMessage = "El nombre es obligatorio.")]
        public string Nombre { get; set; } = string.Empty;

        [Required(ErrorMessage = "El apellido completo es obligatorio.")]
        public string ApellidoCompleto { get; set; } = string.Empty;

        [Required(ErrorMessage = "El correo electrónico es obligatorio.")]
        [EmailAddress(ErrorMessage = "Ingrese una dirección de correo válida.")]
        public string Correo { get; set; } = string.Empty;

        [Required(ErrorMessage = "La contraseña es obligatoria.")]
        [MinLength(8, ErrorMessage = "La contraseña debe contener al menos 8 caracteres.")]
        public string Contrasena { get; set; } = string.Empty;

        [Required(ErrorMessage = "Debe asignar un rol al usuario.")]
        public string Rol { get; set; } = string.Empty;

        public string Estado { get; set; } = "Activo";
    }

    private UsuarioFormModel usuarioForm = new() { Rol = "Administrador" };
    private bool isProcessing = false;

    private async Task GuardarUsuario()
    {
        if (isProcessing) return;
        if (strengthPercent < 100) return; // Validación de fuerza de contraseña
        isProcessing = true;
        try
        {
            EstadoUsuario estadoEnum = usuarioForm.Estado == "Activo" ? EstadoUsuario.ACTIVA : EstadoUsuario.INACTIVA;

            if (usuarioForm.Rol == "Administrador")
            {
                var nuevoAdmin = new Admin
                {
                    dni = usuarioForm.Dni,
                    nombre = usuarioForm.Nombre,
                    apellidoCompleto = usuarioForm.ApellidoCompleto,
                    correo = usuarioForm.Correo,
                    contrasenaHash = usuarioForm.Contrasena,
                    estado = estadoEnum,
                    createdAt = DateTime.Now,
                    updatedAt = DateTime.Now,
                    fechaInicioAdmin = DateTime.Now
                };

                Admin? admin = await AdminsRS.InsertarAsync(nuevoAdmin);
                if (admin != null)
                {
                    usuarioForm = new UsuarioFormModel() { Rol = "Administrador" };
                    Navigation.NavigateTo("/admin/admin-list");
                }
                else
                {
                    Console.WriteLine("Error al guardar el admin en la base de datos.");
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al insertar el nuevo usuario en el sistema: {ex.Message}");
        }
        finally
        {
            isProcessing = false;
        }
    }

    private void Cancelar()
    {
        Navigation.NavigateTo("/admin/admin-list");
    }

    private string PasswordToCheck => usuarioForm.Contrasena;
    private bool hasMinLength => (PasswordToCheck?.Length >= 8);
    private bool hasNumber => !string.IsNullOrEmpty(PasswordToCheck) && PasswordToCheck.Any(char.IsDigit);
    private bool hasUpper => !string.IsNullOrEmpty(PasswordToCheck) && PasswordToCheck.Any(char.IsUpper);
    private bool hasSpecial => !string.IsNullOrEmpty(PasswordToCheck) && PasswordToCheck.Any(c => !char.IsLetterOrDigit(c));

    private int PasswordScore
    {
        get
        {
            if (string.IsNullOrEmpty(PasswordToCheck)) return 0;
            int score = 0;
            if (hasMinLength) score++;
            if (hasNumber) score++;
            if (hasUpper) score++;
            if (hasSpecial) score++;
            return score;
        }
    }

    private string strengthText => PasswordScore switch
    {
        4 => "Fuerte",
        3 => "Media",
        2 => "Media",
        _ => "Débil"
    };

    private string strengthColor => PasswordScore switch
    {
        4 => "#198754", 
        3 => "#ffc107", 
        2 => "#ffc107", 
        _ => "#dc3545"  
    };

    private int strengthPercent => PasswordScore switch
    {
        4 => 100,
        3 => 75,
        2 => 50,
        1 => 25,
        _ => 15
    };
}

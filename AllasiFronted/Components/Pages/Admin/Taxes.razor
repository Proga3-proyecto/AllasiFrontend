@page "/admin/taxes"
@using Microsoft.AspNetCore.Components.Authorization
@layout AdminLayout

@using Progra3_Frontend.Model
@using Progra3_Frontend.Services

@inject ImpuestosRS ImpuestosRS
@inject AlcoholImpuestoRS AlcoholImpuestoRS
@inject ConfirmDialogService DialogService

<AuthorizeView Roles="MASTER" Context="authContext">
    <Authorized>
        <div class="container-fluid mt-3" style="max-width: 1400px;">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="fw-bold text-navy mb-0 main-title">Configuración de Impuestos</h2>
            </div>

            @if (isLoading)
            {
                <div class="text-center py-5">
                    <span class="spinner-border text-navy mb-2" style="width: 3rem; height: 3rem;"></span>
                    <p class="text-muted">Cargando configuración...</p>
                </div>
            }
            else
            {
                <div class="row g-4">
                    <!-- Impuestos Generales -->
                    <div class="col-12 col-xl-6">
                        <div class="card shadow-sm border-0 h-100" style="border-radius: 12px;">
                            <div class="card-header bg-white border-0 pt-4 pb-0 px-4 d-flex justify-content-between align-items-center">
                                <h5 class="fw-bold text-navy mb-0">
                                    <i class="bi bi-percent me-2"></i> Impuestos Generales
                                </h5>
                                <button class="btn btn-sm navy-bg d-flex align-items-center gap-1" style="border-radius: 6px;" @onclick="IniciarNuevoImpuesto">
                                    <i class="bi bi-plus-lg"></i> Añadir
                                </button>
                            </div>
                            <div class="card-body p-4">
                                @if (!impuestos.Any() && !isAddingImpuesto)
                                {
                                    <p class="text-muted text-center my-4">No hay impuestos registrados.</p>
                                }
                                else
                                {
                                    <div class="table-responsive">
                                        <table class="table custom-table align-middle">
                                            <thead>
                                                <tr>
                                                    <th>NOMBRE</th>
                                                    <th class="text-center">PORCENTAJE (%)</th>
                                                    <th class="text-center">ESTADO</th>
                                                    <th class="text-center">ACCIÓN</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @if (isAddingImpuesto)
                                                {
                                                    <tr>
                                                        <td class="fw-bold">
                                                            <input type="text" class="form-control form-control-sm mx-auto text-center" style="max-width: 150px;" @bind="newImpuestoNombre" placeholder="Nombre..." />
                                                        </td>
                                                        <td class="text-center">
                                                            <input type="number" class="form-control form-control-sm mx-auto text-center" style="max-width: 100px;" @bind="newImpuestoPorcentaje" step="0.01" min="0" />
                                                        </td>
                                                        <td class="text-center">
                                                            <select class="form-select form-select-sm mx-auto" style="max-width: 110px;" @bind="newImpuestoActivo">
                                                                <option value="true">Activo</option>
                                                                <option value="false">Inactivo</option>
                                                            </select>
                                                        </td>
                                                        <td class="text-center">
                                                            @if (processingImpuestoId == 0 && processingAction == "Guardar")
                                                            {
                                                                <span class="spinner-border spinner-border-sm text-success" role="status"></span>
                                                            }
                                                            else
                                                            {
                                                                <button class="btn btn-sm btn-success me-1" @onclick="GuardarNuevoImpuesto">
                                                                    <i class="bi bi-check-lg"></i>
                                                                </button>
                                                                <button class="btn btn-sm btn-outline-secondary" @onclick="CancelarNuevoImpuesto">
                                                                    <i class="bi bi-x-lg"></i>
                                                                </button>
                                                            }
                                                        </td>
                                                    </tr>
                                                }
                                                @foreach (var imp in impuestos)
                                                {
                                                    <tr>
                                                        <td class="fw-bold">@imp.nombre</td>
                                                        <td class="text-center">
                                                            @if (editingImpuestoId == imp.id)
                                                            {
                                                                <input type="number" class="form-control form-control-sm mx-auto text-center" style="max-width: 100px;" @bind="editImpuestoPorcentaje" step="0.01" min="0" />
                                                            }
                                                            else
                                                            {
                                                                <span>@imp.porcentaje</span>
                                                            }
                                                        </td>
                                                        <td class="text-center">
                                                            @if (editingImpuestoId == imp.id)
                                                            {
                                                                <select class="form-select form-select-sm mx-auto" style="max-width: 110px;" @bind="editImpuestoActivo">
                                                                    <option value="true">Activo</option>
                                                                    <option value="false">Inactivo</option>
                                                                </select>
                                                            }
                                                            else
                                                            {
                                                                <span class="badge @(imp.activo ? "bg-success" : "bg-danger")">
                                                                    @(imp.activo ? "Activo" : "Inactivo")
                                                                </span>
                                                            }
                                                        </td>
                                                        <td class="text-center">
                                                            @if (editingImpuestoId == imp.id)
                                                            {
                                                                @if (processingImpuestoId == imp.id && processingAction == "Guardar")
                                                                {
                                                                    <span class="spinner-border spinner-border-sm text-success" role="status"></span>
                                                                }
                                                                else
                                                                {
                                                                    <button class="btn btn-sm btn-success me-1" @onclick="() => GuardarImpuesto(imp)">
                                                                        <i class="bi bi-check-lg"></i>
                                                                    </button>
                                                                    <button class="btn btn-sm btn-outline-secondary" @onclick="CancelarEdicionImpuesto">
                                                                        <i class="bi bi-x-lg"></i>
                                                                    </button>
                                                                }
                                                            }
                                                            else
                                                            {
                                                                @if (processingImpuestoId == imp.id && processingAction == "Eliminar")
                                                                {
                                                                    <span class="spinner-border spinner-border-sm text-danger" role="status"></span>
                                                                }
                                                                else
                                                                {
                                                                    <button class="btn btn-sm btn-outline-custom me-1" @onclick="() => IniciarEdicionImpuesto(imp)">
                                                                        <i class="bi bi-pencil"></i>
                                                                    </button>
                                                                    <button class="btn btn-sm btn-danger" @onclick="() => EliminarImpuesto(imp)">
                                                                        <i class="bi bi-trash"></i>
                                                                    </button>
                                                                }
                                                            }
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>

                    <!-- Impuestos Alcohol -->
                    <div class="col-12 col-xl-6">
                        <div class="card shadow-sm border-0 h-100" style="border-radius: 12px;">
                            <div class="card-header bg-white border-0 pt-4 pb-0 px-4 d-flex justify-content-between align-items-center">
                                <h5 class="fw-bold text-navy mb-0">
                                    <i class="bi bi-droplet-half me-2"></i> Impuestos por Grado de Alcohol
                                </h5>
                                <button class="btn btn-sm navy-bg d-flex align-items-center gap-1" style="border-radius: 6px;" @onclick="IniciarNuevoAlcohol">
                                    <i class="bi bi-plus-lg"></i> Añadir
                                </button>
                            </div>
                            <div class="card-body p-4">
                                @if (!alcoholImpuestos.Any() && !isAddingAlcohol)
                                {
                                    <p class="text-muted text-center my-4">No hay impuestos de alcohol registrados.</p>
                                }
                                else
                                {
                                    <div class="table-responsive">
                                        <table class="table custom-table align-middle">
                                            <thead>
                                                <tr>
                                                    <th>RANGO (Grados)</th>
                                                    <th class="text-center">% PRECIO</th>
                                                    <th class="text-center">VALOR (S/.)</th>
                                                    <th class="text-center">ACCIÓN</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @if (isAddingAlcohol)
                                                {
                                                    <tr>
                                                        <td>
                                                            <div class="d-flex align-items-center gap-1">
                                                                <input type="number" class="form-control form-control-sm text-center" @bind="newAlcMin" style="width: 75px;" min="0" />
                                                                <span class="text-muted">-</span>
                                                                <input type="number" class="form-control form-control-sm text-center" @bind="newAlcMax" style="width: 75px;" min="0" />
                                                            </div>
                                                        </td>
                                                        <td class="text-center">
                                                            <input type="number" class="form-control form-control-sm mx-auto text-center" style="max-width: 70px;" @bind="newAlcPorcentaje" min="0" />
                                                        </td>
                                                        <td class="text-center">
                                                            <input type="number" class="form-control form-control-sm mx-auto text-center" style="max-width: 80px;" @bind="newAlcValor" step="0.01" min="0" />
                                                        </td>
                                                        <td class="text-center">
                                                            @if (processingAlcoholId == 0 && processingAction == "Guardar")
                                                            {
                                                                <span class="spinner-border spinner-border-sm text-success" role="status"></span>
                                                            }
                                                            else
                                                            {
                                                                <button class="btn btn-sm btn-success me-1" @onclick="GuardarNuevoAlcohol">
                                                                    <i class="bi bi-check-lg"></i>
                                                                </button>
                                                                <button class="btn btn-sm btn-outline-secondary" @onclick="CancelarNuevoAlcohol">
                                                                    <i class="bi bi-x-lg"></i>
                                                                </button>
                                                            }
                                                        </td>
                                                    </tr>
                                                }
                                                @foreach (var alc in alcoholImpuestos)
                                                {
                                                    <tr>
                                                        <td>
                                                            @if (editingAlcoholId == alc.id)
                                                            {
                                                                <div class="d-flex align-items-center gap-1">
                                                                    <input type="number" class="form-control form-control-sm text-center" @bind="editAlcMin" style="width: 75px;" min="0" />
                                                                    <span class="text-muted">-</span>
                                                                    <input type="number" class="form-control form-control-sm text-center" @bind="editAlcMax" style="width: 75px;" min="0" />
                                                                </div>
                                                            }
                                                            else
                                                            {
                                                                <span>@alc.minimo° - @alc.maximo°</span>
                                                            }
                                                        </td>
                                                        <td class="text-center">
                                                            @if (editingAlcoholId == alc.id)
                                                            {
                                                                <input type="number" class="form-control form-control-sm mx-auto text-center" style="max-width: 70px;" @bind="editAlcPorcentaje" min="0" />
                                                            }
                                                            else
                                                            {
                                                                <span>@alc.porcentajePrecio%</span>
                                                            }
                                                        </td>
                                                        <td class="text-center">
                                                            @if (editingAlcoholId == alc.id)
                                                            {
                                                                <input type="number" class="form-control form-control-sm mx-auto text-center" style="max-width: 80px;" @bind="editAlcValor" step="0.01" min="0" />
                                                            }
                                                            else
                                                            {
                                                                <span>S/ @alc.valor</span>
                                                            }
                                                        </td>
                                                        <td class="text-center">
                                                            @if (editingAlcoholId == alc.id)
                                                            {
                                                                @if (processingAlcoholId == alc.id && processingAction == "Guardar")
                                                                {
                                                                    <span class="spinner-border spinner-border-sm text-success" role="status"></span>
                                                                }
                                                                else
                                                                {
                                                                    <button class="btn btn-sm btn-success me-1" @onclick="() => GuardarAlcohol(alc)">
                                                                        <i class="bi bi-check-lg"></i>
                                                                    </button>
                                                                    <button class="btn btn-sm btn-outline-secondary" @onclick="CancelarEdicionAlcohol">
                                                                        <i class="bi bi-x-lg"></i>
                                                                    </button>
                                                                }
                                                            }
                                                            else
                                                            {
                                                                @if (processingAlcoholId == alc.id && processingAction == "Eliminar")
                                                                {
                                                                    <span class="spinner-border spinner-border-sm text-danger" role="status"></span>
                                                                }
                                                                else
                                                                {
                                                                    <button class="btn btn-sm btn-outline-custom me-1" @onclick="() => IniciarEdicionAlcohol(alc)">
                                                                        <i class="bi bi-pencil"></i>
                                                                    </button>
                                                                    <button class="btn btn-sm btn-danger" @onclick="() => EliminarAlcohol(alc)">
                                                                        <i class="bi bi-trash"></i>
                                                                    </button>
                                                                }
                                                            }
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </Authorized>
    <NotAuthorized>
        <div class="container mt-5">
            <h2 class="text-danger fw-bold">Acceso Denegado</h2>
            <p>Solo los administradores con rol MASTER pueden acceder a la configuración de impuestos.</p>
        </div>
    </NotAuthorized>
</AuthorizeView>

@code {
    private bool isLoading = true;

    private List<Impuesto> impuestos = new();
    private List<AlcoholImpuesto> alcoholImpuestos = new();

    // Estado edición Impuesto general
    private int? editingImpuestoId = null;
    private double editImpuestoPorcentaje;
    private string editImpuestoActivo = "true";

    // Estado edición Impuesto Alcohol
    private int? editingAlcoholId = null;
    private int editAlcMin;
    private int editAlcMax;
    private int editAlcPorcentaje;
    private double editAlcValor;

    // Estados de Carga / Agregar Nuevo
    private int? processingImpuestoId = null;
    private int? processingAlcoholId = null;
    private string processingAction = "";
    
    private bool isAddingAlcohol = false;
    private int newAlcMin;
    private int newAlcMax;
    private int newAlcPorcentaje;
    private double newAlcValor;

    private bool isAddingImpuesto = false;
    private string newImpuestoNombre = "";
    private double newImpuestoPorcentaje = 0;
    private string newImpuestoActivo = "true";

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
    }

    private async Task CargarDatos()
    {
        isLoading = true;
        try
        {
            impuestos = await ImpuestosRS.ListarTodosAsync() ?? new List<Impuesto>();
            alcoholImpuestos = await AlcoholImpuestoRS.ListarTodosAsync() ?? new List<AlcoholImpuesto>();
            
            // Ordenar por minimo de grado alcoholico
            alcoholImpuestos = alcoholImpuestos.OrderBy(a => a.minimo).ToList();
        }
        finally
        {
            isLoading = false;
        }
    }

    private void IniciarEdicionImpuesto(Impuesto imp)
    {
        editingImpuestoId = imp.id;
        editImpuestoPorcentaje = imp.porcentaje;
        editImpuestoActivo = imp.activo ? "true" : "false";
        editingAlcoholId = null;
        isAddingAlcohol = false;
        isAddingImpuesto = false;
    }

    private void CancelarEdicionImpuesto()
    {
        editingImpuestoId = null;
    }

    private async Task GuardarImpuesto(Impuesto imp)
    {
        if (editImpuestoPorcentaje < 0) return;
        bool confirmed = await DialogService.ConfirmAsync("Confirmar Actualización", $"¿Seguro que deseas actualizar {imp.nombre}?");
        if (!confirmed) return;

        processingImpuestoId = imp.id;
        processingAction = "Guardar";
        StateHasChanged();

        imp.porcentaje = editImpuestoPorcentaje;
        imp.activo = editImpuestoActivo == "true";
        
        bool success = await ImpuestosRS.ActualizarAsync(imp);
        if (success)
        {
            editingImpuestoId = null;
            await CargarDatos();
        }
        
        processingImpuestoId = null;
        processingAction = "";
        StateHasChanged();
    }

    private async Task EliminarImpuesto(Impuesto imp)
    {
        bool confirmed = await DialogService.ConfirmAsync("Confirmar Eliminación", $"¿Seguro que deseas eliminar {imp.nombre}?");
        if (!confirmed) return;

        processingImpuestoId = imp.id;
        processingAction = "Eliminar";
        StateHasChanged();

        bool success = await ImpuestosRS.EliminarAsync(imp.id);
        if (success)
        {
            await CargarDatos();
        }
        
        processingImpuestoId = null;
        processingAction = "";
        StateHasChanged();
    }

    private void IniciarEdicionAlcohol(AlcoholImpuesto alc)
    {
        editingAlcoholId = alc.id;
        editAlcMin = alc.minimo;
        editAlcMax = alc.maximo;
        editAlcPorcentaje = alc.porcentajePrecio;
        editAlcValor = alc.valor;
        editingImpuestoId = null;
        isAddingAlcohol = false;
        isAddingImpuesto = false;
    }

    private void CancelarEdicionAlcohol()
    {
        editingAlcoholId = null;
    }

    private async Task GuardarAlcohol(AlcoholImpuesto alc)
    {
        if (editAlcMin < 0 || editAlcMax < 0 || editAlcPorcentaje < 0 || editAlcValor < 0) return;
        bool confirmed = await DialogService.ConfirmAsync("Confirmar Actualización", "¿Seguro que deseas actualizar este impuesto?");
        if (!confirmed) return;

        processingAlcoholId = alc.id;
        processingAction = "Guardar";
        StateHasChanged();

        alc.minimo = editAlcMin;
        alc.maximo = editAlcMax;
        alc.porcentajePrecio = editAlcPorcentaje;
        alc.valor = editAlcValor;
        
        bool success = await AlcoholImpuestoRS.ActualizarAsync(alc);
        if (success)
        {
            editingAlcoholId = null;
            await CargarDatos();
        }

        processingAlcoholId = null;
        processingAction = "";
        StateHasChanged();
    }

    private async Task EliminarAlcohol(AlcoholImpuesto alc)
    {
        bool confirmed = await DialogService.ConfirmAsync("Confirmar Eliminación", "¿Seguro que deseas eliminar este impuesto?");
        if (!confirmed) return;

        processingAlcoholId = alc.id;
        processingAction = "Eliminar";
        StateHasChanged();

        bool success = await AlcoholImpuestoRS.EliminarAsync(alc.id);
        if (success)
        {
            await CargarDatos();
        }
        
        processingAlcoholId = null;
        processingAction = "";
        StateHasChanged();
    }

    private void IniciarNuevoAlcohol()
    {
        isAddingAlcohol = true;
        newAlcMin = 0;
        newAlcMax = 0;
        newAlcPorcentaje = 0;
        newAlcValor = 0;
        
        editingAlcoholId = null;
        editingImpuestoId = null;
        isAddingImpuesto = false;
    }

    private void CancelarNuevoAlcohol()
    {
        isAddingAlcohol = false;
    }

    private async Task GuardarNuevoAlcohol()
    {
        if (newAlcMin < 0 || newAlcMax < 0 || newAlcPorcentaje < 0 || newAlcValor < 0) return;
        bool confirmed = await DialogService.ConfirmAsync("Confirmar Creación", "¿Seguro que deseas crear este nuevo impuesto?");
        if (!confirmed) return;

        processingAlcoholId = 0; // 0 significa 'nuevo' en este contexto
        processingAction = "Guardar";
        StateHasChanged();

        var nuevoAlc = new AlcoholImpuesto
        {
            minimo = newAlcMin,
            maximo = newAlcMax,
            porcentajePrecio = newAlcPorcentaje,
            valor = newAlcValor
        };
        
        int newId = await AlcoholImpuestoRS.InsertarAsync(nuevoAlc);
        if (newId > 0)
        {
            isAddingAlcohol = false;
            await CargarDatos();
        }
        
        processingAlcoholId = null;
        processingAction = "";
        StateHasChanged();
    }

    private void IniciarNuevoImpuesto()
    {
        isAddingImpuesto = true;
        newImpuestoNombre = "";
        newImpuestoPorcentaje = 0;
        newImpuestoActivo = "true";

        editingImpuestoId = null;
        editingAlcoholId = null;
        isAddingAlcohol = false;
    }

    private void CancelarNuevoImpuesto()
    {
        isAddingImpuesto = false;
    }

    private async Task GuardarNuevoImpuesto()
    {
        if (string.IsNullOrWhiteSpace(newImpuestoNombre) || newImpuestoPorcentaje < 0) return;
        bool confirmed = await DialogService.ConfirmAsync("Confirmar Creación", $"¿Seguro que deseas crear el impuesto {newImpuestoNombre}?");
        if (!confirmed) return;

        processingImpuestoId = 0;
        processingAction = "Guardar";
        StateHasChanged();

        var nuevoImp = new Impuesto
        {
            nombre = newImpuestoNombre,
            porcentaje = newImpuestoPorcentaje,
            activo = newImpuestoActivo == "true",
            tipo = TipoImpuesto.PORCENTAJE // Default
        };
        
        try
        {
            await ImpuestosRS.InsertarAsync(nuevoImp);
            isAddingImpuesto = false;
            await CargarDatos();
        }
        catch (Exception) { }
        
        processingImpuestoId = null;
        processingAction = "";
        StateHasChanged();
    }
}

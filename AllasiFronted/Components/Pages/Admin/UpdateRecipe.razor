@page "/admin/update-recipe"
@page "/admin/update-recipe/{Id:int}"
@layout AdminLayout

@using System.ComponentModel.DataAnnotations
@using Progra3_Frontend.Model
@using Progra3_Frontend.Services
@using Microsoft.AspNetCore.Components.Forms

@inject NavigationManager Navigation
@inject RecetasRS RecetasRS
@inject ProductosRS ProductosRS

@using Microsoft.AspNetCore.Components.Authorization

<AuthorizeView Roles="ADMIN" Context="authContext">
    <Authorized>
        <div class="container-fluid mt-3 mb-4">

    <div class="text-center mb-3">
        <h2 class="fw-bold text-navy"
            style="letter-spacing: 0.5px; font-size: 1.35rem;">
            Modificar Receta
        </h2>
    </div>

    <div class="form-container">

        <EditForm Model="recetaViewModel"
                  OnValidSubmit="ActualizarReceta">

            <DataAnnotationsValidator />

            @if (!string.IsNullOrWhiteSpace(mensajeError))
            {
                <div class="alert alert-danger py-2 mb-3"
                     style="font-size: 0.82rem;">
                    <i class="bi bi-exclamation-circle me-2"></i>
                    @mensajeError
                </div>
            }

            <div class="row gx-4 align-items-stretch">

                <div class="col-md-4 mb-3 mb-md-0 d-flex flex-column">

                    <label class="form-label-custom d-block mb-2">
                        Imagen de la receta
                    </label>

                            <div class="d-flex flex-wrap gap-2 p-2" style="border: 1px solid #e0e0e0; border-radius: 8px; background-color: #fafafa; min-height: 150px; flex-grow: 1;">

                                @foreach (var img in imagenes)
                                {
                                    <div class="image-card" style="width: 100px; height: 130px; border: 1px solid #ccc; border-radius: 8px; position: relative; overflow: hidden; display: flex; flex-direction: column; background: white;">
                                        <img src="@img.PreviewUrl" style="width: 100%; height: 80px; object-fit: cover;" alt="Vista previa" />

                                        <div class="p-1 text-center d-flex align-items-center justify-content-center gap-1" style="flex-grow: 1; background: #f8f9fa;">
                                            <input type="radio" name="principalImage" checked="@img.IsPrincipal" @onchange="() => SetPrincipal(img)" title="Marcar como principal" style="cursor:pointer;" />
                                            <small style="font-size: 0.65rem; font-weight: 500;">Principal</small>
                                        </div>

                                        <button type="button" class="btn btn-sm btn-danger p-0 d-flex align-items-center justify-content-center" style="position: absolute; top: 4px; right: 4px; width: 22px; height: 22px; border-radius: 50%; font-size: 0.8rem;" @onclick="() => RemoverImagen(img)">
                                            <i class="bi bi-x"></i>
                                        </button>
                                    </div>
                                }

                                <label class="image-card" style="width: 100px; height: 130px; border: 2px dashed #bbb; border-radius: 8px; display: flex; align-items: center; justify-content: center; cursor: pointer; background-color: white; margin-bottom: 0; transition: background 0.2s;">
                                    <InputFile OnChange="HandleFileSelected" accept="image/*" multiple style="display: none;" />
                                    <i class="bi bi-plus-lg" style="font-size: 2rem; color: #888;"></i>
                                </label>

                            </div>

                </div>

                <div class="col-md-8">

                    <div class="row mb-3">

                        <div class="col-md-6">

                            <label class="form-label-custom">
                                Nombre de la receta
                                <span class="asterisk">*</span>
                            </label>

                            <div class="input-container">
                                <i class="bi bi-journal-text"></i>

                                <input type="text"
                                       placeholder="Ej: Pisco Sour"
                                       @bind="recetaViewModel.nombre" />
                            </div>

                            <ValidationMessage For="@(() => recetaViewModel.nombre)"
                                               class="validation-text" />

                        </div>

                        <div class="col-md-6">

                            <label class="form-label-custom">
                                Precio (S/)
                                <span class="asterisk">*</span>
                            </label>

                            <div class="input-container">
                                <i class="bi bi-cash"></i>

                                <input type="number"
                                       step="0.01"
                                       min="0"
                                       placeholder="Ej: 35.00"
                                       @bind="recetaViewModel.precio" />
                            </div>

                            <ValidationMessage For="@(() => recetaViewModel.precio)"
                                               class="validation-text" />

                        </div>

                    </div>

                    <div class="row mb-3">

                        <div class="col-md-6">

                            <label class="form-label-custom">
                                Descuento (%)
                                <span class="asterisk">*</span>
                            </label>

                            <div class="input-container">
                                <i class="bi bi-tag"></i>

                                <input type="number"
                                       step="0.01"
                                       min="0"
                                       max="100"
                                       placeholder="Ej: 0"
                                       @bind="recetaViewModel.descuento" />
                            </div>

                            <ValidationMessage For="@(() => recetaViewModel.descuento)"
                                               class="validation-text" />

                        </div>

                        <div class="col-md-6">

                            <label class="form-label-custom">
                                Precio final
                            </label>

                            <div class="input-container">
                                <i class="bi bi-cash-coin"></i>

                                <input type="text"
                                       value="@CalcularPrecioFinal().ToString("0.00")"
                                       readonly />
                            </div>

                        </div>

                    </div>

                    <div class="row mb-3">

                        <div class="col-12">

                            <label class="form-label-custom">
                                Descripción
                                <span class="asterisk">*</span>
                            </label>

                            <div class="input-container">
                                <i class="bi bi-card-text"></i>

                                <textarea rows="3"
                                          placeholder="Describe brevemente la receta"
                                          @bind="recetaViewModel.descripcion">
                                </textarea>
                            </div>

                            <ValidationMessage For="@(() => recetaViewModel.descripcion)"
                                               class="validation-text" />

                        </div>

                    </div>

                </div>

                <div class="mt-4 pt-3"
                     style="border-top: 1px solid rgba(170,170,170,0.3);">

                    <div class="d-flex justify-content-between align-items-center mb-3">

                        <div>
                            <h5 class="fw-bold text-navy mb-1"
                                style="font-size: 1rem;">
                                Productos de la receta
                            </h5>

                            <small class="text-muted">
                                Modifica los productos requeridos o cambia sus cantidades.
                            </small>
                        </div>

                        <button type="button"
                                class="btn btn-outline-custom"
                                style="border-radius: 6px; font-size: 0.82rem; padding: 6px 14px;"
                                @onclick="AgregarProducto">

                            <i class="bi bi-plus-lg me-1"></i>
                            Añadir producto
                        </button>

                    </div>

                    @if (cargandoDatos)
                    {
                        <div class="text-center text-muted py-3">
                            <span class="spinner-border spinner-border-sm me-2"></span>
                            Cargando información de la receta...
                        </div>
                    }
                    else
                    {
                        @for (int i = 0; i < ingredientes.Count; i++)
                        {
                            int indice = i;

                            <div class="row g-2 align-items-end mb-2"
                                 @key="ingredientes[indice]">

                                <div class="col-md-7">

                                    <label class="form-label-custom">
                                        Producto @(indice + 1)
                                        <span class="asterisk">*</span>
                                    </label>

                                    <div class="input-container">
                                        <i class="bi bi-box-seam"></i>

                                        <input type="text" list="productosList" placeholder="Ej: Pisco Quebranta" @bind="ingredientes[indice].ProductoNombreTemporal" />
                                    </div>


                                </div>

                                <div class="col-md-3">

                                    <label class="form-label-custom">
                                        Cantidad
                                        <span class="asterisk">*</span>
                                    </label>

                                    <div class="input-container">
                                        <i class="bi bi-calculator"></i>

                                        <input type="number"
                                               step="0.01"
                                               min="0.01"
                                               placeholder="Ej: 1"
                                               @bind="ingredientes[indice].Cantidad" />
                                    </div>

                                </div>

                                <div class="col-md-2">

                                    <button type="button"
                                            class="btn btn-danger w-100"
                                            style="border-radius: 6px; font-size: 0.82rem; padding: 6px 14px;"
                                            @onclick="() => QuitarProducto(indice)">
                                        <i class="bi bi-trash"></i>
                                    </button>

                                </div>

                            </div>
                        }

                        <datalist id="productosList">
                            @if (productosDisponibles != null)
                            {
                                @foreach (var producto in productosDisponibles)
                                {
                                    <option value="@producto.nombre"></option>
                                }
                            }
                        </datalist>
                    }

                </div>

                <div class="mt-4 pt-3"
                     style="border-top: 1px solid rgba(170,170,170,0.3);">

                    <h5 class="fw-bold text-navy mb-1" style="font-size: 1rem;">
                        Instrucciones de preparación
                        <span class="asterisk">*</span>
                    </h5>

                    <small class="text-muted d-block mb-2">
                        Modifica el procedimiento paso a paso. Presiona Enter para saltar de línea.
                    </small>

                    <div class="input-container">
                        <i class="bi bi-list-check"></i>
                        <textarea rows="6"
                                  placeholder="Escribe aquí las instrucciones de preparación..."
                                  @bind="recetaViewModel.instrucciones">
                        </textarea>
                    </div>

                    <ValidationMessage For="@(() => recetaViewModel.instrucciones)"
                                       class="validation-text" />

                </div>

                <div class="d-flex justify-content-end gap-2 mt-3 pt-3"
                     style="border-top: 1px solid rgba(170,170,170,0.3);">

                    <button type="button"
                            class="btn btn-outline-custom"
                            style="border-radius: 6px; font-size: 0.82rem; padding: 6px 14px;"
                            @onclick='() => Navigation.NavigateTo("/admin/recipe-list")'>
                        Cancelar
                    </button>

                    <button type="submit"
                            class="btn navy-bg"
                            disabled="@guardando"
                            style="border-radius: 6px; font-weight: 500; font-size: 0.82rem; padding: 6px 14px;">

                        @if (guardando)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                            <span>Guardando cambios...</span>
                        }
                        else
                        {
                            <span>Guardar Cambios</span>
                        }

                    </button>

                </div>

            </div>

        </EditForm>

    </div>

</div>

    </Authorized>
    <NotAuthorized>
        <div class="container mt-5">
            <h2>Acceso denegado</h2>
            <p>No tienes permisos para acceder a esta página.</p>
        </div>
    </NotAuthorized>
</AuthorizeView>

@code {
    [Parameter] public int Id { get; set; }

    public class RecetaViewModel
    {
        [Required(ErrorMessage = "El nombre es obligatorio")]
        public string nombre { get; set; } = string.Empty;

        [Required(ErrorMessage = "La descripción es obligatoria")]
        public string descripcion { get; set; } = string.Empty;

        [Required(ErrorMessage = "El precio es obligatorio")]
        [Range(0.01, double.MaxValue, ErrorMessage = "El precio debe ser mayor a 0")]
        public double? precio { get; set; }

        [Required(ErrorMessage = "El descuento es obligatorio (0 si no aplica)")]
        [Range(0, 100, ErrorMessage = "El descuento debe estar entre 0 y 100")]
        public double? descuento { get; set; }

        [Required(ErrorMessage = "Las instrucciones de preparación son obligatorias")]
        public string instrucciones { get; set; } = string.Empty;
    }

    public class IngredienteViewModel
    {
        public int ProductoId { get; set; }
        public double? Cantidad { get; set; }
        public string ProductoNombreTemporal { get; set; } = string.Empty;
    }

    public class ImageItem
    {
        public IBrowserFile? File { get; set; }
        public bool IsExisting { get; set; } = false;
        public int Id { get; set; }
        public string PreviewUrl { get; set; } = string.Empty;
        public bool IsPrincipal { get; set; } = false;
        public byte[] FileContent { get; set; } = Array.Empty<byte>();
    }

    private List<ImageItem> imagenes = new();
    private long maxFileSize = 1024 * 1024 * 5;

    private RecetaViewModel recetaViewModel { get; set; } = new();
    private List<Producto> productosDisponibles = new();
    private List<IngredienteViewModel> ingredientes = [new()];
    private string mensajeError = string.Empty;
    private bool cargandoDatos;
    private bool guardando;

    protected override async Task OnInitializedAsync()
    {
        cargandoDatos = true;
        await CargarProductos();
        await CargarRecetaExistente();
        cargandoDatos = false;
    }

    private async Task CargarProductos()
    {
        try
        {
            productosDisponibles = await ProductosRS.ListarTodosAsync() ?? new List<Producto>();
        }
        catch (Exception ex)
        {
            mensajeError = $"Error cargando productos: {ex.Message}";
        }
    }

    private async Task CargarRecetaExistente()
    {
        if (Id <= 0) return;

        try
        {
            // Se consume el servicio para obtener la receta actual por su Id
            Receta? receta = await RecetasRS.ObtenerPorIdAsync(Id);

            if (receta != null)
            {
                recetaViewModel.nombre = receta.nombre;
                recetaViewModel.descripcion = receta.descripcion;
                recetaViewModel.precio = receta.precio;
                recetaViewModel.descuento = receta.descuento;

                // PROCESO INVERSO: Convierte el <br /> almacenado de vuelta a saltos de línea ordinarios (\n) para el textarea
                if (!string.IsNullOrWhiteSpace(receta.instrucciones))
                {
                    recetaViewModel.instrucciones = receta.instrucciones
                        .Replace("<br />", "\n")
                        .Replace("<br>", "\n");
                }

                // Mapear los elementos existentes al listado dinámico del ViewModel
                if (receta.elementos != null && receta.elementos.Count > 0)
                {
                    ingredientes = receta.elementos.Select(e => new IngredienteViewModel
                    {
                        ProductoId = e.producto?.id ?? 0,
                        ProductoNombreTemporal = e.producto?.nombre ?? string.Empty,
                        Cantidad = e.cantidad
                    }).ToList();
                }

                if (receta.imagenes != null && receta.imagenes.Any())
                {
                    imagenes.Clear();
                    foreach (var img in receta.imagenes)
                    {
                        imagenes.Add(new ImageItem
                        {
                            PreviewUrl = img.url,
                            IsPrincipal = img.principal,
                            IsExisting = true,
                            Id = img.id,
                            File = null
                        });
                    }
                }
            }
            else
            {
                mensajeError = "No se encontró la receta seleccionada.";
            }
        }
        catch (Exception ex)
        {
            mensajeError = $"Error al obtener los datos de la receta: {ex.Message}";
        }
    }

    private double CalcularPrecioFinal()
    {
        double precio = recetaViewModel.precio ?? 0;
        double descuento = recetaViewModel.descuento ?? 0;
        double precioFinal = precio - (precio * descuento / 100.0);
        return Math.Round(Math.Max(0, precioFinal), 2);
    }

    private void AgregarProducto() => ingredientes.Add(new IngredienteViewModel());

    private void QuitarProducto(int indice)
    {
        if (ingredientes.Count == 1)
        {
            ingredientes[0] = new IngredienteViewModel();
            return;
        }
        ingredientes.RemoveAt(indice);
    }

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        foreach (var file in e.GetMultipleFiles())
        {
            try
            {
                var resizedImage = await file.RequestImageFileAsync(file.ContentType, 300, 300);
                using var previewStream = new MemoryStream();
                await resizedImage.OpenReadStream().CopyToAsync(previewStream);
                var previewUrl = $"data:{file.ContentType};base64,{Convert.ToBase64String(previewStream.ToArray())}";
                using var originalStream = new MemoryStream();
                await file.OpenReadStream(maxFileSize).CopyToAsync(originalStream);

                var nuevaImagen = new ImageItem
                {
                    File = file,
                    PreviewUrl = previewUrl,
                    FileContent = originalStream.ToArray(),
                    IsPrincipal = (imagenes.Count == 0) 
                };

                imagenes.Add(nuevaImagen);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error procesando la imagen {file.Name}: {ex.Message}");
            }
        }
    }

    private void SetPrincipal(ImageItem selectedImg)
    {
        foreach (var img in imagenes)
        {
            img.IsPrincipal = (img == selectedImg);
        }
    }

    private void RemoverImagen(ImageItem imgToRemove)
    {
        imagenes.Remove(imgToRemove);
        if (imgToRemove.IsPrincipal && imagenes.Count > 0)
        {
            imagenes[0].IsPrincipal = true;
        }
    }

    private async Task ActualizarReceta()
    {
        mensajeError = string.Empty;

        foreach (var ing in ingredientes)
        {
            var p = productosDisponibles.FirstOrDefault(x => string.Equals(x.nombre, ing.ProductoNombreTemporal?.Trim(), StringComparison.OrdinalIgnoreCase));
            if (p != null)
            {
                ing.ProductoId = p.id;
            }
            else
            {
                ing.ProductoId = 0;
            }
        }

        List<IngredienteViewModel> ingredientesValidos = ingredientes
            .Where(ingrediente =>
                ingrediente.ProductoId > 0 &&
                ingrediente.Cantidad.HasValue &&
                ingrediente.Cantidad.Value > 0
            )
            .ToList();

        if (ingredientesValidos.Count == 0)
        {
            mensajeError = "Debes añadir por lo menos un producto a la receta (verifica que el nombre sea válido).";
            return;
        }

        if (ingredientesValidos.GroupBy(i => i.ProductoId).Any(g => g.Count() > 1))
        {
            mensajeError = "No puedes seleccionar el mismo producto más de una vez.";
            return;
        }

        try
        {
            guardando = true;

            // Almacenar nuevamente convirtiendo los saltos de línea a HTML <br />
            string instruccionesFormateadas = recetaViewModel.instrucciones
                .Replace("\r\n", "<br />")
                .Replace("\n", "<br />");

            List<ElementoReceta> elementos = ingredientesValidos
                .Select(ingrediente => new ElementoReceta
                {
                    producto = new Producto { id = ingrediente.ProductoId },
                    cantidad = ingrediente.Cantidad ?? 0
                })
                .ToList();

            Receta recetaActualizada = new Receta
            {
                id = Id, // Se adjunta el ID correspondiente para efectuar el cambio en BD
                nombre = recetaViewModel.nombre.Trim(),
                descripcion = recetaViewModel.descripcion.Trim(),
                instrucciones = instruccionesFormateadas.Trim(),
                precio = recetaViewModel.precio ?? 0,
                precioFinal = CalcularPrecioFinal(),
                descuento = recetaViewModel.descuento ?? 0,
                elementos = elementos
            };

            // Se invoca al método ActualizarAsync que retorna un booleano (Igual que en UpdateProduct)
            bool resultado = await RecetasRS.ActualizarAsync(recetaActualizada);

            if (resultado)
            {
                if (imagenes.Count > 0)
                {
                    foreach (var img in imagenes)
                    {
                        if (img.IsExisting)
                        {
                            if (img.IsPrincipal)
                            {
                                try
                                {
                                    await RecetasRS.SubirImagenPrincipalAsync(Id, img.Id);
                                }
                                catch (Exception ex)
                                {
                                    Console.WriteLine($"Error actualizando imagen principal existente: {ex.Message}");
                                }
                            }
                            continue;
                        }
                        try
                        {
                            using var stream = new MemoryStream(img.FileContent);
                            Imagen? imagenDB = await RecetasRS.SubirImagenAsync(Id, stream, img.File!.Name, img.File!.ContentType);
                            
                            if (imagenDB != null && img.IsPrincipal)
                            {
                                await RecetasRS.SubirImagenPrincipalAsync(Id, imagenDB.id);
                            }
                        }
                        catch (Exception ex)
                        {
                            Console.WriteLine($"Error subiendo imagen {img.File!.Name}: {ex.Message}");
                        }
                    }
                }

                Navigation.NavigateTo("/admin/recipe-list");
            }
            else
            {
                mensajeError = "No se pudieron guardar las modificaciones en la base de datos.";
            }
        }
        catch (Exception ex)
        {
            mensajeError = $"Error al actualizar la receta: {ex.Message}";
            Console.WriteLine(mensajeError);
        }
        finally
        {
            guardando = false;
        }
    }
}
@page "/admin/report-client"
@layout AdminLayout

@inject NavigationManager Navigation

@using Microsoft.AspNetCore.Components.Authorization
@using Progra3_Frontend.Model
@using Progra3_Frontend.Services

@using Microsoft.JSInterop
@using QuestPDF.Fluent
@using QuestPDF.Helpers
@using QuestPDF.Infrastructure

@inject IJSRuntime JS


@inject PedidosRS pedidosRS

<AuthorizeView Roles="ADMIN" Context="authContext">
    <Authorized>
        <div class="client-report-page container-fluid mt-3 mb-4">

    <div class="report-header">

        <div class="d-flex align-items-center gap-2">

            <button type="button"
                    class="btn navy-bg"
                    @onclick='() => Navigation.NavigateTo("/admin/report-list")'>

                <i class="bi bi-arrow-left me-1"></i>
                Regresar
            </button>

			<button type="button"
					class="btn navy-bg"
					@onclick="ExportarPdf">

				<i class="bi bi-download me-1"></i>
				Exportar PDF
			</button>

        </div>


        <div>
            <h2 class="report-title text-navy">
                Reporte por Cliente
            </h2>

            <p class="report-subtitle">
                Consulta el DNI y el total comprado de cada cliente.
            </p>
        </div>


    </div>

    <div class="filter-panel"
         style="grid-template-columns: 1fr 1fr;">

        <div class="filter-group">

            <label>Ordenar por</label>

            <div class="input-container">
                <i class="bi bi-filter"></i>

                <select @bind="CriterioOrden">
                    <option value="cantidad">
                        Total comprado
                    </option>

                    <option value="nombre">
                        Nombre
                    </option>
                </select>
            </div>

        </div>

        <div class="filter-group">

            <label>Tipo de orden</label>

            <div class="input-container">
                <i class="bi bi-sort-down"></i>

                <select @bind="TipoOrden">
                    <option value="descendente">
                        Mayor a menor
                    </option>

                    <option value="ascendente">
                        Menor a mayor
                    </option>
                </select>
            </div>

        </div>

    </div>

    <div class="table-container">

        <div class="table-responsive">

            <table class="table custom-table table-borderless align-middle w-100">

                <thead>
                    <tr>
                        <th class="text-start">
                            CLIENTE
                        </th>

                        <th class="text-center">
                            DNI
                        </th>

                        <th class="text-center">
                            TOTAL COMPRADO
                        </th>
                    </tr>
                </thead>

                <tbody>
                    @if (isLoading)
                    {
                        <tr>
                            <td colspan="3" class="text-center py-5 text-muted">
                                <div class="d-flex flex-column align-items-center justify-content-center">
                                    <span class="spinner-border text-navy mb-2" role="status" aria-hidden="true" style="width: 2rem; height: 2rem;"></span>
                                    <span>Cargando reporte...</span>
                                </div>
                            </td>
                        </tr>
                    }
                    else if (!ClientesOrdenados.Any())
                    {
                        <tr>
                            <td colspan="3" class="text-center py-4 text-muted">
                                <em>No se encontraron datos.</em>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var cliente in ClientesOrdenados)
                        {
                            <tr>

                                <td class="text-start">

                                    <div class="d-flex align-items-center gap-2">

                                        <div class="summary-icon"
                                             style="width: 36px;
                                            height: 36px;">

                                            <i class="bi bi-person-circle"></i>
                                        </div>

                                        <span class="fw-bold text-navy">
                                            @cliente.Nombre
                                        </span>

                                    </div>

                                </td>

                                <td class="text-center text-nowrap">

                                    <span class="fw-bold text-dark">
                                        @cliente.Dni
                                    </span>

                                </td>

                                <td class="text-center text-nowrap">

                                    <span class="fw-bold text-navy">
                                        S/ @cliente.TotalComprado.ToString("0.00")
                                    </span>

                                </td>

                            </tr>
                        }
                    }
                </tbody>

            </table>

        </div>

    </div>

</div>


    </Authorized>
    <NotAuthorized>
        <div class="container mt-5">
            <h2>Acceso denegado</h2>
            <p>No tienes permisos para acceder a esta página.</p>
        </div>
    </NotAuthorized>
</AuthorizeView>
@code {
    private string CriterioOrden { get; set; } = "cantidad";

    private string TipoOrden { get; set; } = "descendente";

    private List<ClienteReporte> Clientes { get; set; }
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
        List<Pedido> pedidos = await pedidosRS.ListarTodosAsync();

		Clientes = pedidos
			.Where(pedido => pedido.cliente != null)
			.GroupBy(pedido => pedido.cliente.idUsuario)
			.Select(grupo => new ClienteReporte
			{
				Nombre = grupo.First().cliente.nombre + " " +
						 grupo.First().cliente.apellidoCompleto,

				Dni = grupo.First().cliente.dni,

				TotalComprado = grupo.Sum(pedido => pedido.precioFinal)
			}).ToList();

        isLoading = false;
    }


    private IEnumerable<ClienteReporte> ClientesOrdenados
    {
        get
        {
            if (Clientes == null) return [];

            if (CriterioOrden == "nombre")
            {
                return TipoOrden == "ascendente"
                    ? Clientes.OrderBy(cliente => cliente.Nombre)
                    : Clientes.OrderByDescending(cliente => cliente.Nombre);
            }

            return TipoOrden == "ascendente"
                ? Clientes.OrderBy(cliente => cliente.TotalComprado)
                : Clientes.OrderByDescending(cliente => cliente.TotalComprado);
        }
    }

    private class ClienteReporte
    {
        public string Nombre { get; set; } = string.Empty;

        public string Dni { get; set; } = string.Empty;

        public double TotalComprado { get; set; }
    }
	
		public async Task ExportarPdf()
    {
        QuestPDF.Settings.License = LicenseType.Community;

        List<ClienteReporte> clientesExportar =
            ClientesOrdenados.ToList();

        double totalGeneral = clientesExportar.Sum(
            cliente => cliente.TotalComprado
        );

        List<ClienteReporte> clientesGrafica = clientesExportar
            .OrderByDescending(cliente => cliente.TotalComprado)
            .Take(10)
            .ToList();

        double compraMaxima = clientesGrafica.Count > 0
            ? clientesGrafica.Max(cliente => cliente.TotalComprado)
            : 1;

        string fechaGeneracion =
            DateTime.Now.ToString("dd/MM/yyyy HH:mm");

        const string azulPrincipal = "#101C45";
        const string azulClaro = "#EEF2FF";
        const string textoPrincipal = "#1E293B";
        const string textoSecundario = "#64748B";
        const string fondoAlterno = "#F8FAFC";
        const string bordeGris = "#E2E8F0";

        byte[] pdf = Document.Create(document =>
        {
            document.Page(page =>
            {
                page.Size(PageSizes.A4);
                page.Margin(30);
                page.PageColor(Colors.White);

                page.DefaultTextStyle(style => style
                    .FontSize(9)
                    .FontColor(textoPrincipal)
                );

                /* =========================================
                   ENCABEZADO
                   ========================================= */

                page.Header().Column(header =>
                {
                    header.Item().Row(row =>
                    {
                        row.RelativeItem().Column(title =>
                        {
                            title.Item()
                                .Text("Reporte por Cliente")
                                .FontSize(21)
                                .FontColor(azulPrincipal)
                                .Bold();

                            title.Item()
                                .PaddingTop(3)
                                .Text(
                                    "Resumen de compras realizadas por cada cliente"
                                )
                                .FontSize(9)
                                .FontColor(textoSecundario);
                        });

                        row.ConstantItem(170).Column(info =>
                        {
                            info.Item()
                                .AlignRight()
                                .Text("Fecha de generación")
                                .FontSize(8)
                                .FontColor(textoSecundario);

                            info.Item()
                                .PaddingTop(3)
                                .AlignRight()
                                .Text(fechaGeneracion)
                                .FontSize(9)
                                .SemiBold();
                        });
                    });

                    header.Item()
                        .PaddingTop(12)
                        .LineHorizontal(2)
                        .LineColor(azulPrincipal);
                });

                /* =========================================
                   CONTENIDO
                   ========================================= */

                page.Content()
                    .PaddingTop(18)
                    .PaddingBottom(15)
                    .Column(column =>
                    {
                        column.Spacing(14);

                        /* Tarjetas de resumen */

                        column.Item().Row(row =>
                        {
                            row.RelativeItem()
                                .PaddingRight(6)
                                .Background(azulClaro)
                                .Border(1)
                                .BorderColor(bordeGris)
                                .Padding(14)
                                .Column(card =>
                                {
                                    card.Item()
                                        .Text("TOTAL DE CLIENTES")
                                        .FontSize(8)
                                        .FontColor(textoSecundario)
                                        .SemiBold();

                                    card.Item()
                                        .PaddingTop(5)
                                        .Text(clientesExportar.Count.ToString())
                                        .FontSize(18)
                                        .FontColor(azulPrincipal)
                                        .Bold();
                                });

                            row.RelativeItem()
                                .PaddingLeft(6)
                                .Background(azulClaro)
                                .Border(1)
                                .BorderColor(bordeGris)
                                .Padding(14)
                                .Column(card =>
                                {
                                    card.Item()
                                        .Text("TOTAL GENERAL COMPRADO")
                                        .FontSize(8)
                                        .FontColor(textoSecundario)
                                        .SemiBold();

                                    card.Item()
                                        .PaddingTop(5)
                                        .Text($"S/ {totalGeneral:N2}")
                                        .FontSize(18)
                                        .FontColor(azulPrincipal)
                                        .Bold();
                                });
                        });

                        /* Título de tabla */

                        column.Item()
                            .PaddingTop(5)
                            .Column(title =>
                            {
                                title.Item()
                                    .Text("Detalle de clientes")
                                    .FontSize(14)
                                    .FontColor(azulPrincipal)
                                    .Bold();

                                title.Item()
                                    .PaddingTop(2)
                                    .Text(
                                        "Listado de clientes y monto total comprado"
                                    )
                                    .FontSize(8)
                                    .FontColor(textoSecundario);
                            });

                        /* Tabla */

                        column.Item()
                            .Border(1)
                            .BorderColor(bordeGris)
                            .Table(table =>
                            {
                                table.ColumnsDefinition(columns =>
                                {
                                    columns.RelativeColumn();
                                    columns.ConstantColumn(100);
                                    columns.ConstantColumn(125);
                                });

                                table.Header(header =>
                                {
                                    header.Cell()
                                        .Background(azulPrincipal)
                                        .PaddingVertical(8)
                                        .PaddingHorizontal(7)
                                        .Text("CLIENTE")
                                        .FontSize(8)
                                        .FontColor(Colors.White)
                                        .Bold();

                                    header.Cell()
                                        .Background(azulPrincipal)
                                        .PaddingVertical(8)
                                        .PaddingHorizontal(7)
                                        .Text("DNI")
                                        .FontSize(8)
                                        .FontColor(Colors.White)
                                        .Bold();

                                    header.Cell()
                                        .Background(azulPrincipal)
                                        .PaddingVertical(8)
                                        .PaddingHorizontal(7)
                                        .AlignRight()
                                        .Text("TOTAL COMPRADO")
                                        .FontSize(8)
                                        .FontColor(Colors.White)
                                        .Bold();
                                });

                                for (
                                    int indice = 0;
                                    indice < clientesExportar.Count;
                                    indice++
                                )
                                {
                                    ClienteReporte cliente =
                                        clientesExportar[indice];

                                    string fondoFila = indice % 2 == 0
                                        ? Colors.White
                                        : fondoAlterno;

                                    table.Cell()
                                        .Background(fondoFila)
                                        .BorderBottom(1)
                                        .BorderColor(bordeGris)
                                        .PaddingVertical(7)
                                        .PaddingHorizontal(7)
                                        .Text(cliente.Nombre ?? "");

                                    table.Cell()
                                        .Background(fondoFila)
                                        .BorderBottom(1)
                                        .BorderColor(bordeGris)
                                        .PaddingVertical(7)
                                        .PaddingHorizontal(7)
                                        .Text($"{cliente.Dni}");

                                    table.Cell()
                                        .Background(fondoFila)
                                        .BorderBottom(1)
                                        .BorderColor(bordeGris)
                                        .PaddingVertical(7)
                                        .PaddingHorizontal(7)
                                        .AlignRight()
                                        .Text(
                                            $"S/ {cliente.TotalComprado:N2}"
                                        )
                                        .SemiBold();
                                }

                                /* Fila total */

                                table.Cell()
                                    .ColumnSpan(2)
                                    .Background(azulClaro)
                                    .PaddingVertical(9)
                                    .PaddingHorizontal(7)
                                    .AlignRight()
                                    .Text("TOTAL GENERAL")
                                    .FontColor(azulPrincipal)
                                    .Bold();

                                table.Cell()
                                    .Background(azulClaro)
                                    .PaddingVertical(9)
                                    .PaddingHorizontal(7)
                                    .AlignRight()
                                    .Text($"S/ {totalGeneral:N2}")
                                    .FontColor(azulPrincipal)
                                    .Bold();
                            });

                        /* Gráfica */

                        if (clientesGrafica.Count > 0)
                        {
                            column.Item()
                                .PaddingTop(10)
                                .Column(title =>
                                {
                                    title.Item()
                                        .Text(
                                            "Clientes con mayor total comprado"
                                        )
                                        .FontSize(14)
                                        .FontColor(azulPrincipal)
                                        .Bold();

                                    title.Item()
                                        .PaddingTop(2)
                                        .Text(
                                            "Los 10 clientes con los mayores montos acumulados"
                                        )
                                        .FontSize(8)
                                        .FontColor(textoSecundario);
                                });

                            column.Item()
                                .Background(fondoAlterno)
                                .Border(1)
                                .BorderColor(bordeGris)
                                .Padding(15)
                                .Column(chart =>
                                {
                                    chart.Spacing(10);

                                    foreach (
                                        ClienteReporte cliente
                                        in clientesGrafica
                                    )
                                    {
                                        float porcentaje = compraMaxima > 0
                                            ? (float)(
                                                cliente.TotalComprado /
                                                compraMaxima *
                                                100
                                            )
                                            : 0;

                                        porcentaje = Math.Clamp(
                                            porcentaje,
                                            1f,
                                            100f
                                        );

                                        float restante =
                                            Math.Max(100f - porcentaje, 0f);

                                        chart.Item().Column(bar =>
                                        {
                                            bar.Item().Row(row =>
                                            {
                                                row.RelativeItem()
                                                    .Text(
                                                        cliente.Nombre ?? ""
                                                    )
                                                    .FontSize(8)
                                                    .SemiBold();

                                                row.ConstantItem(105)
                                                    .AlignRight()
                                                    .Text(
                                                        $"S/ {cliente.TotalComprado:N2}"
                                                    )
                                                    .FontSize(8)
                                                    .FontColor(azulPrincipal)
                                                    .Bold();
                                            });

                                            bar.Item()
                                                .PaddingTop(4)
                                                .Height(13)
                                                .Row(row =>
                                                {
                                                    row.RelativeItem(porcentaje)
                                                        .Background(
                                                            azulPrincipal
                                                        );

                                                    if (restante > 0)
                                                    {
                                                        row.RelativeItem(restante)
                                                            .Background(
                                                                "#DDE3EC"
                                                            );
                                                    }
                                                });
                                        });
                                    }
                                });
                        }
                        else
                        {
                            column.Item()
                                .PaddingTop(10)
                                .Background(fondoAlterno)
                                .Border(1)
                                .BorderColor(bordeGris)
                                .Padding(15)
                                .AlignCenter()
                                .Text(
                                    "No existen datos para generar la gráfica."
                                )
                                .FontColor(textoSecundario);
                        }
                    });

                /* =========================================
                   PIE DE PÁGINA
                   ========================================= */

                page.Footer().Column(footer =>
                {
                    footer.Item()
                        .LineHorizontal(1)
                        .LineColor(bordeGris);

                    footer.Item()
                        .PaddingTop(7)
                        .Row(row =>
                        {
                            row.RelativeItem()
                                .Text("Reporte por Cliente")
                                .FontSize(8)
                                .FontColor(textoSecundario);

                            row.RelativeItem()
                                .AlignRight()
                                .Text(text =>
                                {
                                    text.DefaultTextStyle(style => style
                                        .FontSize(8)
                                        .FontColor(textoSecundario)
                                    );

                                    text.Span("Página ");
                                    text.CurrentPageNumber();
                                    text.Span(" de ");
                                    text.TotalPages();
                                });
                        });
                });
            });
        }).GeneratePdf();

        await JS.InvokeVoidAsync(
            "descargarArchivo",
            $"ReporteClientes_{DateTime.Now:yyyyMMdd_HHmm}.pdf",
            "application/pdf",
            Convert.ToBase64String(pdf)
        );
    }

}
